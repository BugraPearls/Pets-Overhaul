Mods: {
	PetsOverhaul: {
		Misc: {
			CurrentSimple: "[c/42a8ff:按下] <switchKey> [c/42a8ff:以切换为详细描述，查看具体数值等]"
			CurrentDetailed: "[c/42a8ff:按下] <switchKey> [c/42a8ff:以切换为简洁描述，方便阅读]"
			BaseCd: 基础宠物技能冷却：
			NoCd: 当前宠物没有技能冷却！
			RemainingCd: 剩余宠物技能冷却：
			ReadyCd: 宠物技能就绪！

					Tooltip: 灰尘的生成率为正常的 0.5 倍。
					Label: 降低
				}

				Normal: {
					Tooltip: 默认，灰尘的生成率为 1 倍。
					Label: 正常
				}

				Increased: {
					Tooltip: 灰尘的生成率为正常的 2 倍。
					Label: 增加
				}
			}

			PassivePetSoundFrequency: {
				Tooltip: ""

				None: {
					Tooltip: 完全禁用宠物发出的被动环境音效。
					Label: 从不
				}

				Lowered: {
					Tooltip: 宠物的被动环境音效大约每 5 分钟播放一次。
					Label: 稀有
				}

				Normal: {
					Tooltip: 宠物的被动环境音效大约每 2 分钟播放一次。
					Label: 正常
				}

				Increased: {
					Tooltip: 宠物的被动环境音效大约每 1 分钟播放一次。
					Label: 频繁
				}
			}
		}

		Achievements: {
			NeedOfCompany: {
				Description: 装备任意常规宠物或照明宠物。此举会吸引城镇NPC「驯宠师」的注意。
				FriendlyName: 相伴之需
			}

			MasteryCraft: {
				Description: 使用怪物低概率掉落的大师碎片，制作任意一个大师模式专属宠物物品。
				FriendlyName: 大师工艺
			}

			ForgingPets: {
				Description: 在宠物锻造炉上，使用宠物食物及其他对应材料，制作任意一个宠物物品。话说驯宠师到底从哪搞来这么多宠物锻造炉？
				FriendlyName: 宠物锻铸
			}

			QuestionableKibble: {
				Description: 将任意宠物物品投入微光中，最终只会转化为宠物食品。就算有微光这闪亮的奇异液体掺和，也丝毫掩盖不了这事本身的骇人与离谱。
				FriendlyName: 可疑口粮
			}

			Purrfection: {
				Description: 在驯宠师处将两个照明宠物合成，获得一个满品质的照明宠物。我，完美无缺。
				FriendlyName: 臻至喵境
			}

			TheCollector: {
				Description: 至少装备过游戏内所有常规宠物各一次。
				FriendlyName: 宠物收藏家
			}

			GottaPetThemAll: {
				FriendlyName: 全宠撸遍
				Description: 抚摸每一只城镇宠物，依次获取它们对应的全部增益效果。
			}

			GleamingCollection: {
				FriendlyName: 辉光收藏家
				Description: 至少装备过游戏内所有照明宠物各一次。
			}

			UnpaidLabor: {
				FriendlyName: 无偿苦力
				Description: 通过通用、采掘、采集、钓鱼等各类宠物，获取总价值不低于5铂金币的物品。
			}

			HextupleJumper: {
				FriendlyName: 六段跳大师
				Description: 装备耳廓狐宠物，或骑乘坐骑时装备史莱姆公主宠物，完成6次及以上的额外跳跃。
			}

			IAmUntouchable: {
				FriendlyName: 我，无人能及
				Description: 装备地牢守卫宝宝宠物进入地牢。地牢里的弱小威胁，都将在你面前俯首称臣。
			}

			Petception: {
				Description: 从蓝鸡宠物的额外掉落中获取蓝鸡蛋、桉树汁或魔法南瓜子。
				FriendlyName: 盗宠空间
			}

			AbsoluteZero: {
				FriendlyName: 绝对零度
				Description: 穿戴全套冰霜盔甲时，通过小雪人宠物减速敌人。没有比这更激冻人心的场面了。
			}

			Vulnerable: {
				FriendlyName: 致命破绽
				Description: 攻击被狼人宝宝宠物施加了满层「重伤」减益的敌人，该效果会使敌人承受更多伤害。
			}

			ISeeWhatYoureDoing: {
				FriendlyName: 我知道你在做什么
				Description: 装备小松露人宠物时，修改左右移动的按键绑定。这下这只宠物没任何负面效果了，对吧？
			}

			Arsonist: {
				Description: 通过伯尼宠物，累计延长「燃烧」减益效果时长达到1小时。你感觉自己的理智正在恢复……
				FriendlyName: 纵火狂
			}

			BringsBadLuckAfterall: {
				Description: 连续3次触发黑猫宠物的技能并受到伤害。看来迷信终究是有道理的。
				FriendlyName: 迷信诚不欺我
			}

			HeavyDutyPet: {
				Description: 用雷管小猫宠物的单次爆炸同时命中10名敌人。
				FriendlyName: 重磅战宠
			}

			AnotherWorld: {
				FriendlyName: 异界同行
				Description: 旧日军团事件进行期间，装备双足翼龙蛋，食人魔棍棒，龙蛋，Gato蛋或飞眼怪蛋。
			}

			FakeHarpy: {
				FriendlyName: 冒牌鸟妖
				Description: 装备小女妖宠物在太空层飞行时，耗尽飞行时间。连滑翔都不会？真是个山寨货。
			}

			IveFoundYourEye: {
				FriendlyName: 以眼还眼
				Description: 装备弹簧眼宠物时，击杀眼怪。全数奉还。
			}

			PrettyButteryFlight: {
				FriendlyName: 蝶影翩飞
				Description: 装备闪光蝴蝶宠物时，达成5.5秒及以上的连续飞行时间。信不信由你，苍蝇可不喜欢黄油。
			}

			ThisWontBeHowIDie: {
				Description: 装备Spiffo宠物时，累计击杀100只僵尸类敌人。看来你这次能活下来了。
				FriendlyName: 我不会就此殒命
			}

			TheSummit: {
				Description: 将祝尼魔宠物的三项技能全部提升至50级。“漫漫长路终有尽头……我们真为你骄傲！”
				FriendlyName: 登峰造极
			}

			PlantaHermano: {
				Description: 装备泥芽宠物时，在1秒内连续食用玉米片和辣椒。话说鳄梨酱去哪了？
				FriendlyName: 植物兄弟
			}

			NutritiousDecoy: {
				Description: 操控蜥蜴宠物丢下蜥蜴断尾，再将其从地面捡起，恢复生命值并刷新技能冷却。
				FriendlyName: 营养诱饵
			}

			Muncher: {
				Description: 通过猪人宠物累计节省50个食物或药水。饿坏了。
				FriendlyName: 大胃王
			}

			LootChaser: {
				Description: 从暗影宝箱怪宠物的额外掉落中获取50件掉落概率低于25%的物品。
				FriendlyName: 宝藏猎人
			}

			ElusiveHunter: {
				Description: 装备小狗宠物击杀或捕捉15只稀有生物，以获取额外金币并高亮标记它们。天生的猎手。
				FriendlyName: 天生猎手
			}

			Copycat: {
				Description: 让你的鹦鹉宠物累计发射250发复制弹幕。让你的鹦鹉宠物累计发射250发复制弹幕。啥？
				FriendlyName: 回响形态
			}

			UnstoppableAndImmovable: {
				Description: 当泰拉瑞亚中无坚不摧的 “矛”—— 正在全力冲锋的巨型陆龟，撞上坚不可摧的 “盾”—— 开启乌龟宠物硬化甲壳技能的你，会发生什么？
				FriendlyName: 以子之矛，攻子之盾
			}

			WarriorPet: {
				Description: 通过宠物造成的伤害累计达到25000点，包括宠物生成的弹幕，或是宠物效果造成的直接伤害。
				FriendlyName: 宠物之剑
			}

			TooMuchHoney: {
				Description: 装备闪耀蜂蜜时，饮用瓶装蜂蜜或食用蜂蜜鱼。多人模式下，你摄入超量糖分的操作，也会让你的队友们从中受益。
				FriendlyName: 蜂蜜过量
			}

			SagePet: {
				Description: 通过宠物的治疗效果累计恢复15000点生命值，宠物提供的任何生命回复也会计入。
				FriendlyName: 宠物之光
			}

			HoverboardSkater: {
				Description: 装备异星滑板小子宠物水平飞行，累计节省10分钟的飞行时间。反正往上飞也没什么意思。
				FriendlyName: 悬浮滑板滑手
			}

			GuardPet: {
				Description: 通过宠物效果提供的护盾，累计格挡5000点伤害。
				FriendlyName: 宠物之盾
			}

			FreezingTheReaper: {
				Description: 通过冰雪女王宠物的效果，阻挡一次致死攻击。
				FriendlyName: 冻结死神
			}

			YouAndSlimeArmy: {
				Description: 同时拥有5只存活的史莱姆仆从——它们是由皇家怡口或华美甜点宠物技能召唤的、为你而战的友方单位。
				FriendlyName: 黏滑军团统御者
			}

			TooManyBobbers: {
				Description: 装备小猪龙鱼宠物钓鱼时，额外抛出2个鱼漂。
				FriendlyName: 超多浮标
			}

			INeededALittleMoreTime: {
				Description: 在小骷髅王宠物施加的持续伤害即将超过你最大生命值时，饮用药水提升生命值上限，撑过这次持续伤害。
				FriendlyName: 再给我一点时间吧
			}

			FreezingRage: {
				Description: 当小独眼巨鹿宠物的技能储存伤害达到最大值（相当于你最大生命值的50%）时，用技能命中扇形范围中心区域的敌人。处于中心区域的敌人，会被此次攻击无视防御！
				FriendlyName: 冰封之怒
			}

			DefensiveBuild: {
				Description: 通过可疑眼睛宠物的技能，牺牲所有防御能力和最大生命值，获得100点及以上的暴怒值，以此大幅提升你的输出能力。
				FriendlyName: “肉装”
			}

			CrispyFriedCalamari: {
				Description: 将月亮乌贼投入微光中，将其转化为宠物食品。听着挺香的，但为啥要这么做？还是说你本来期待能变出点别的？
				FriendlyName: 香炸鱿鱼圈
			}

			AncientSorcery: {
				Description: 在18秒内，使用幻影龙宝宝宠物的3种不同法术。不知道拜月教邪教徒看了会不会刮目相看。
				FriendlyName: 远古咒术
			}
		}
	}
}

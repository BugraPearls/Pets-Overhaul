					Label: Comum
				}
			}

			MaxLightPetCelebration: {
				Tooltip: ""

				None: {
					Label: Desativado
					Tooltip: Desativa completamente quaisquer efeitos visuais e sonoros ao obter um PET de Luz Perfeito.
				}

				Lowered: {
					Label: Reduzido
					Tooltip: Mostra uma mensagem pop-up e um curto som de guitarra ao obter um PET de Luz Perfeito.
				}

				Normal: {
					Label: Normal
					Tooltip: Mostra um pop-up e uma mensagem no chat, confetes e um som de guitarra ao obter um PET de Luz Perfeito.
				}

				Increased: {
					Label: Aumentado
					Tooltip: Mostra um pop-up e uma mensagem no chat, confetes, fogos de artifício e um som prolongado de guitarra ao obter um PET de Luz Perfeito.
				}
			}
		}

		Achievements: {
			NeedOfCompany: {
				Description: Equipe qualquer Mascote Normal ou de Luz. Isso chamará a atenção do NPC Domador de Mascotes.
				FriendlyName: Precisando de Companhia
			}

			MasteryCraft: {
				Description: Crie qualquer Item de Mascote do Modo Mestre usando o item Fragmento de Maestria. Que dropa raramente de inimigos.
				FriendlyName: Criação de Maestria
			}

			ForgingPets: {
				Description: Crie qualquer Mascote em uma Forja de Mascotes usando Comida de Mascote, junto de outros itens relevantes. De onde o Domador de Mascotes tira todas essas Forjas de Mascotes?
				FriendlyName: Forjando Mascotes
			}

			QuestionableKibble: {
				Description: Jogue um Item de Mascote no Shimmer, onde você só obterá Comida de Mascote como resultado. Um líquido brilhante estar envolvido não faz isso soar melhor.
				FriendlyName: Ração Questionável
			}

			Purrfection: {
				Description: Combine dois Mascotes de Luz no Domador de Mascotes para obter qualquer Mascote de Luz com a qualidade máxima possível. Eu sou perfeito.
				FriendlyName: Perfeição
			}

			TheCollector: {
				Description: Equipe todos os Mascotes Normais do jogo pelo menos uma vez.
				FriendlyName: O Colecionador
			}

			GottaPetThemAll: {
				FriendlyName: Temos Que Fazer Carinho Em Todos
				Description: Faça carinho em todos os Mascotes da Cidade para obter todos os seus respectivos buffs um por um.
			}

			GleamingCollection: {
				FriendlyName: Coleção Cintilante
				Description: Equipe todos os Mascotes de Luz do jogo pelo menos uma vez.
			}

			UnpaidLabor: {
				FriendlyName: Trabalho Não Remunerado
				Description: Obtenha um total de 5 moedas de platina em valor de itens dos seus Mascotes, como Mascotes Utilitários, de Mineração, Colheita ou Pesca.
			}

			HextupleJumper: {
				FriendlyName: Saltador Sêxtuplo
				Description: Execute 6 Pulos Bônus enquanto usa o Mascote Raposa-do-Deserto, Princesa Fada ou Princesa Slime em uma montaria.
			}

			IAmUntouchable: {
				FriendlyName: Eu Sou Intocável
				Description: Entre na Masmorra com o Mascote Bebê Guardião da Masmorra equipado. Os perigos fracos da Masmorra se curvam diante de você.
			}

			Petception: {
				Description: Obtenha um Ovo de Galinha Azul, uma Seiva de Eucalipto ou uma Semente de Abóbora Mágica enquanto ganha drops extras com o Mascote Galinha Azul.
				FriendlyName: Petception
			}

			AbsoluteZero: {
				FriendlyName: Zero Absoluto
				Description: Desacelere um inimigo com o Mascote Bebê Boneco de Neve enquanto usa a Armadura de Gelo completa. Não fica mais frio que isso.
			}

			Vulnerable: {
				FriendlyName: Vulnerável
				Description: Golpeie um inimigo que possui o máximo de acúmulos do debuff Esfaqueado, aplicado pelo Mascote Bebê Lobisomem, fazendo com que ele receba mais dano.
			}

			ISeeWhatYoureDoing: {
				FriendlyName: Eu Vejo O Que Você Está Fazendo
				Description: Mude os controles de movimento para esquerda e para direita enquanto o Mascote Bebê Trufa estiver equipado. O Mascote não tem nenhuma desvantagem agora, não é mesmo?
			}

			Arsonist: {
				Description: Estenda um total de 1 hora da duração do debuff de Queimadura usando o Mascote Bernie. Você pode sentir sua sanidade retornando...
				FriendlyName: Incendiário
			}

			BringsBadLuckAfterall: {
				Description: Receba dano usando a habilidade do Gato Preto 3 vezes seguidas. As superstições estavam certas afinal.
				FriendlyName: Traz Má Sorte Afinal
			}

			HeavyDutyPet: {
				Description: Golpeie 10 inimigos ao mesmo tempo com uma explosão do seu Mascote Gatinho Dinamite.
				FriendlyName: Mascote Pesado
			}

			AnotherWorld: {
				FriendlyName: Outro Mundo
				Description: Tenha equipado a Itsy Betsy, Bebê Ogro, Hoardagron, Propeller Gato ou Flickerwick enquanto o evento do Exército do Ancião estiver ativo.
			}

			FakeHarpy: {
				FriendlyName: Harpia Falsa
				Description: Fique sem Tempo de Asa enquanto voa no Espaço usando o Mascote Lil' Harpy. Você nem consegue planar? Que imitação barata.
			}

			IveFoundYourEye: {
				FriendlyName: Eu Encontrei O Seu Olho
				Description: Mate um Olho a Laser enquanto o Mascote Olho de Mola estiver equipado. Retornar ao remetente.
			}

			PrettyButteryFlight: {
				FriendlyName: Voo Bem Amanteigado
				Description: Atinja 5,5 segundos ou mais de tempo de voo enquanto usa o Mascote Borboleta Brilhante. Acredite ou não, moscas não gostam de manteiga.
			}

			ThisWontBeHowIDie: {
				Description: Mate um total de 100 inimigos do tipo Zumbi enquanto o Mascote Spiffo estiver equipado. Eu acho que você viverá mais um dia.
				FriendlyName: Não É Assim Que Vou Morrer
			}

			TheSummit: {
				Description: Alcance o Nível 50 nas três habilidades do seu Mascote Junimo. "Foi uma longa estrada... E você nos deixou muito orgulhosos!"
				FriendlyName: O Cume
			}

			PlantaHermano: {
				Description: Enquanto você tiver o Mascote Plantero equipado, coma Nachos e Pimenta Picante em menos de um segundo. Mas onde está a guacamole?
				FriendlyName: Planta Hermano
			}

			NutritiousDecoy: {
				Description: Solte uma Cauda de Lagarto com o seu Mascote Lagarto e pegue-a de volta do chão, repondo a saúde e recuperando seu tempo de recarga.
				FriendlyName: Isca Nutritiva
			}

			Muncher: {
				Description: Guarde 50 Itens de Comida ou Poções usando o seu Mascote Porco-Homem. Com muita fome.
				FriendlyName: Comilão
			}

			LootChaser: {
				Description: Encontre 50 itens com chance inferior a 25% de dropar de saques de Inimigos ou Bolsas de Saque com o Mascote Mímico das Sombras, já que o Mascote aumenta as chances.
				FriendlyName: Caçador de Saque
			}

			ElusiveHunter: {
				Description: Mate ou capture 15 criaturas raras com o Mascote Cachorrinho para ganhar dinheiro bônus e localizá-las facilmente. Um caçador nato.
				FriendlyName: Caçador Elusivo
			}

			Copycat: {
				Description: Faça seu Mascote Papagaio disparar 250 projéteis duplicados. Faça seu Mascote Papagaio disparar 250 projéteis duplicados. O quê?
				FriendlyName: Imitador
			}

			UnstoppableAndImmovable: {
				Description: O que aconteceria se a força implacável do Terraria, a Tartaruga Gigante que está atacando, encontrasse um objeto imóvel: você com o Mascote Tartaruga, quando a habilidade Casco Endurecido do seu Mascote está ativa.
				FriendlyName: Força Implacável vs Objeto Imóvel
			}

			WarriorPet: {
				Description: Cause 25000 de dano com danos originados por Mascotes. Seja através de projéteis criados por seus Mascotes ou danos diretos de seus efeitos.
				FriendlyName: Mascote Guerreiro
			}

			TooMuchHoney: {
				Description: Consuma Mel Engarrafado ou Honeyfin usando o Mascote Abelha de Mel. No multiplayer, seus amigos vão apreciar você com uma overdose de açúcar.
				FriendlyName: Mel Demais
			}

			SagePet: {
				Description: Cure 15000 de vida com Curas de Mascotes. Qualquer recuperação de saúde de seus Mascotes conta para isso.
				FriendlyName: Mascote Sábio
			}

			HoverboardSkater: {
				Description: Economize 10 minutos de Tempo de Asa voando no eixo X com o Mascote Skatista Alienígena. Voar para cima é sem graça de qualquer forma.
				FriendlyName: Skatista de Hoverboard
			}

			GuardPet: {
				Description: Bloqueie 5000 de dano com Escudos dos Efeitos de seus Mascotes.
				FriendlyName: Mascote Guarda
			}

			FreezingTheReaper: {
				Description: Sobreviva a um acerto fatal com o efeito da sua Mascote Rainha do Gelo.
				FriendlyName: Congelando o Ceifador
			}

			YouAndSlimeArmy: {
				Description: Tenha 5 Servos Slimes vivos ao mesmo tempo, um NPC amigável que lutará por você, convocado pela habilidade do Mascote Príncipe Slime ou Mascotes Reais Slime.
				FriendlyName: Você e o Exército de Slime
			}

			TooManyBobbers: {
				Description: Jogue 2 iscas extras enquanto pesca usando o Mascote Peixe-dragão Minúsculo.
				FriendlyName: Muitas Iscas
			}

			INeededALittleMoreTime: {
				Description: Receba mais dano do que 100% da sua vida em dano ao longo do tempo pelo seu Mascote Esqueletron Jr., e beba uma Poção para aumentar sua saúde o suficiente para sobreviver ao dano ao longo do tempo.
				FriendlyName: Eu Precisava de um Pouco Mais de Tempo
			}

			FreezingRage: {
				Description: Acerte inimigos no meio do cone da habilidade do Mascote Minideerclops, quando o dano armazenado for o máximo; 50% da sua vida. Os inimigos no centro terão sua defesa ignorada para o acerto!
				FriendlyName: Fúria Congelante
			}

			DefensiveBuild: {
				Description: Obtenha 100 ou mais Pontos de Raiva sacrificando todas as suas capacidades defensivas e saúde máxima ao usar a Habilidade do seu Mascote Olho Suspeito, para aumentar muito suas capacidades ofensivas.
				FriendlyName: '''"Build Defensiva"'''
			}

			CrispyFriedCalamari: {
				Description: Jogue o Mascote Moonling no Shimmer para transformá-lo em Comida de Mascote. Parece delicioso, mas por quê? Ou você esperava algo diferente da Comida de Mascote.
				FriendlyName: Lula Frita Crocante
			}

			AncientSorcery: {
				Description: Use todos os 3 feitiços diferentes do Mascote Dragão Fantasmal dentro de 18 segundos. O Cultista Lunático pode ou não ficar impressionado.
				FriendlyName: Feitiçaria Antiga
			}

			PeakGenetics: {
				Description: Obtenha um PET de Luz com a qualidade máxima possível em todos os atributos, sem combinar PETs de Luz. Você tem muita sorte!
				FriendlyName: Genética de Ponta
			}
		}
	}
}

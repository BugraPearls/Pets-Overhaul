				Normal: {
					Tooltip: Padrão, taxa de geração de 1x para poeiras.
					Label: Normal
				}

				Increased: {
					Tooltip: As poeiras são geradas com 2x a taxa normal.
					Label: Aumentada
				}
			}

			PassivePetSoundFrequency: {
				Tooltip: ""

				None: {
					Tooltip: Desabilita completamente os efeitos sonoros ambientes passivos originados dos seus Mascotes.
					Label: Nunca
				}

				Lowered: {
					Tooltip: Sons passivos ambientes dos Mascotes tocarão em aproximadamente a cada 5~ minutos.
					Label: Raro
				}

				Normal: {
					Tooltip: Sons passivos ambientes dos Mascotes tocarão em aproximadamente a cada 2~ minutos.
					Label: Normal
				}

				Increased: {

		Items: {
			GlommersGoop: {
				DisplayName: Gosma de Glommer
				Tooltip: '''"Inseto estranho faz cocô estranho."'''
				Mana: Consome 50 de sanidade. (Mana no mundo de Terraria.)
			}

			EndlessBalloonSack: {
				DisplayName: Saco de Balões Infinitos
				Tooltip: Preenchido com a banheira inteira da Garota de Festa
			}

			MasteryShard: {
				DisplayName: Fragmento de Maestria
				Tooltip:
					'''
					Um ingrediente principal de criação em receitas de Mascotes do Modo Mestre.
					Raramente dropado por qualquer chefe e extremamente raro de ser dropado por qualquer inimigo.
					Apenas uma vez por mundo, dropa com 100% de chance de 5 chefes específicos.
					'''
			}

			Egg: {
				DisplayName: Ovo
				Tooltip:
					'''
					É uma 'pena' não ser azul.
					Diferente de Ovos Podres, parece que pode ser cozido.
					'''
			}

			LihzahrdWrench: {
				DisplayName: Chave Inglesa Lihzahrd
				Tooltip: Consuma isso para desbloquear a receita de criação do Mascote de Luz Golem de Brinquedo permanentemente.
			}

			PrismaticOptic: {
				DisplayName: Óptica Prismática
				Tooltip: Consuma isso para desbloquear a receita de criação do Mascote de Luz Princesa Fada permanentemente.
			}

			PumpkingsHead: {
				DisplayName: Cabeça do Reibóbora
				Tooltip:
					'''
					A colheita deste ano parece ser bem abundante.
					Consuma isso para desbloquear a receita de criação do Mascote de Luz Jack 'O Lantern permanentemente.
					'''
			}

			PetMonitoringTablet: {
				DisplayName: Tablet de Monitoramento de Mascotes
				Tooltip:
					'''
					Mostra todas as estatísticas do Jogador relacionadas ao Pets Overhaul.
					Potência de Lentidão do Mascote: <slow>x
					[c/899499:Quando os inimigos são desacelerados pelos seus Mascotes, eles são desacelerados em <slowValue>% do valor original.]
					Aceleração de Habilidade do Mascote: <haste>%
					[c/899499:As habilidades do seu Mascote recarregam <hasteValue>% <hastePosiOrNega> do que o normal.]
					Multiplicador de Dano do Mascote: <damage>x
					[c/899499:Projéteis e Danos Diretos originados de seus Mascotes causam <damageTooltip>% de dano.]
					Multiplicador de Cura do Mascote: <heal>x
					[c/899499:Qualquer tipo de cura originada de seus Mascotes cura <healTooltip>% a mais.]
					Multiplicador de Escudo do Mascote: <shield>x
					[c/899499:Todos os efeitos de escudo de seus Mascotes concedem <shieldTooltip>% de escudo.]
					Fortuna Global: <global>
					[c/899499:Todos os drops de Mineração, Colheita e Pesca são aumentados em <globalTooltip>%.]
					[c/899499:Também aumenta todos os drops de itens de Mascote não classificados em <globalTooltipIncr>%.]
					Fortuna de Mineração: <mining> (Minérios etc., veja todos com /pet items mining)
					[c/899499:Todos os drops de Mineração são aumentados em <miningTooltip>%. Se o item for de um Mascote, aumenta para <miningTooltipIncr>%.]
					Fortuna de Colheita: <harvesting> (Árvores, plantas, etc., veja todos com /pet items harvesting)
					[c/899499:Todos os drops de Colheita são aumentados em <harvestingTooltip>%. Se o item for de um Mascote, aumenta para <harvestingTooltipIncr>%.]
					Fortuna de Pesca: <fishing> (Capturas de pesca, veja todos com /pet items fishing)
					[c/899499:Todos os drops de Pesca são aumentados em <fishingTooltip>%. Se o item for de um Mascote, aumenta para <fishingTooltipIncr>%.]
					Itens de Mascotes de Luz do Modo Mestre Consumidos: <items>
					'''
			}

			Bonemerang: {
				DisplayName: Ossomerangue
				Tooltip: Você ainda pode ouvi-lo chorando pelos seus pais.
			}

			PetForgeItem: {
				DisplayName: Forja de Mascotes
				Tooltip:
					'''
					Permite que você crie todos os Mascotes.
					Meticulosamente projetada pelo Grande Domador de Mascotes.
					'''
			}

			PetFood: {
				DisplayName: Comida de Mascote
				Tooltip:
					'''
					Não há nenhum Mascote que essa comida multissabor não agrade!
					Usada nas receitas de criação de cada um dos Mascotes.
					Obtida de várias maneiras, vendida pelo Domador de Mascotes. Jogar Mascotes no Shimmer resultará apenas em Comida de Mascote. 
					'''
			}
		}

		Projectiles: {

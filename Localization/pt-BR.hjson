Mods: {
	PetsOverhaul: {
		Misc: {
			CurrentSimple: "[c/42a8ff:Pressione] <switchKey> [c/42a8ff:para alternar para a dica de ferramenta detalhada, para números etc.]"
			CurrentDetailed: "[c/42a8ff:Pressione] <switchKey> [c/42a8ff:para alternar para a dica de ferramenta simples, para simplicidade.]"
			BaseCd: Temporizador Base de Habilidade de PET:
			NoCd: O PET Atual não tem um Temporizador de Habilidade!
			RemainingCd: Temporizador de Habilidade do PET Restante:
			ReadyCd: Habilidade de PET Pronta!
			Sec: Segundo
			Secs: Segundos
			Pet: PET
			OutOf: de
			And: e
			Ability: Habilidade
			Faster: Mais Rápido
			Slower: Mais Lerdo
			RequireOptic: Consumindo uma Óptica Prismática
			RequireWrench: Consumindo uma Chave Inglesa Lagharto
			RequireHead: Consumindo uma Cabeça de Abóbora
			Herb: Erva
			Animal: Animal
			RarePlant: Plantas raras
			KeybindMissing: Atalho de Teclado não Registrado
			NonCustomLineContributor: "[c/a3bdf8:Pressione] <switchKey> [c/a3bdf8:para alternar para o efeito Personalizado de Contribuidor deste mascote.]"
			NonCustomLineDonator: "[c/a3bdf8:Pressione] <switchKey> [c/a3bdf8:para alternar para o efeito Personalizado de Doador deste mascote.]"
			CustomLine: "[c/a3bdf8:Pressione] <switchKey> [c/a3bdf8:para voltar ao efeito padrão deste mascote.]"
			Notice:
				'''
				[c/90C2AA:Pets Overhaul 3.9, mudanças mais recentes: Retrabalho dos Pets de Luz & mudanças de balanceamento, correções importantes e melhorias no sistema]
				[c/b4bfc5:Entre no nosso servidor do discord para feedback, relatar problemas & perguntas! discord.gg/KubSpqvDGE]
				[c/b4bfc5:Dê uma olhada na nossa Wiki: terrariamods.wiki.gg/wiki/Pets_Overhaul]
				[c/b4bfc5:Use] [c/ff8234:/pet] [c/b4bfc5:para ver os comandos do Pets Overhaul!]
				'''
			Current: Atual
			Enabled: Habilitado
			Disabled: Desabilitado
			TownPetBuffTip: Apenas um bônus de mascote da cidade pode estar ativo por vez.
			TownPetPetMe: " (Me faça carinho!)"
			ActivePetSlotHover:
				'''
				Qualquer Item de Pet colocado neste slot terá seus efeitos ativos.
				Ele substituirá o Slot de Pet atual.
				Este Pet não será visível de forma alguma.
				Este Pet é salvo e trocado com o seu Loadout selecionado.
				'''
			EnemyUntargetable: Alvo Inacessível!
		}

		GameTips: {
			LightPetStatTip: A quantidade de atributos que seus PETs de Luz concedem é aleatória! Eles são determinados no momento em que você obtém o PET, e a sua Sorte afeta isso.
			PetClassTip: Você pode usar PETs que não são da 'Sua classe'! PETs de bônus gerais que são Ofensivos, Defensivos, de Mobilidade, de Utilidade e de Suporte são todos viáveis!
			PetFoodTip: Jogar um Item de PET no Shimmer dará apenas Comida para PET, que pode ser usada para criar PETs.
			LightPetCombineTip: Os atributos dos PETs de Luz não podem ser aumentados de forma alguma, exceto pela combinação de PETs de Luz.
			GatheringTip: Os efeitos de coleta dos PETs de Mineração, Colheita e Pesca geralmente funcionam no momento em que você realmente pega o item.
			PettingTip: Fazer carinho nos PETs da Cidade e nos Slimes concede buffs que fortalecem seus PETs.
		}

		Classes: {
			None: Nenhum
			Melee: Físico
			Ranged: A Distância
			Magic: Mágico
			Summoner: Invocação
			Utility: Utilitário
			Mobility: Mobilidade
			Harvesting: Colheita
			Mining: Minerador
			Fishing: Pescador
			Offensive: Ofensivo
			Defensive: Defensivo
			Supportive: Suporte
		}

		Commands: {
			Help:
				'''
				[c/90C2AA:Lista de comandos do Pets Overhaul:] (os comandos não diferenciam maiúsculas de minúsculas)
				/pet fortune, /pet fortunestat, /pet fortunestats -> Mostra seus status atuais de fortuna e explica sua funcionalidade.
				/pet vanity, /pet vanitypet -> Explica como usar um pet 'Estético'.
				/pet lb, /pet junimo, /pet junimoscoreboard, /pet junimoleaderboard -> Mostra os 3 melhores jogadores online com as maiores contagens de Exp para todas as 3 habilidades de Junimo.
				/pet mine|fish|harv, /pet {mining|fishing|harvesting}scoreboard, /pet {mining|fishing|harvesting}leaderboard -> 
				Mostra uma quantidade ilimitada de jogadores online com as maiores contagens de Exp na habilidade escolhida entre as 3 habilidades de Junimo.
				/pet faq, /pet question -> Mostra perguntas frequentes sobre o Pets Overhaul.
				/pet pets, class {all, ability (or cooldown)<petClasses>}
				-> Mostra todos os PET's no chat que possuem a classe informada no segundo argumento. O argumento 'all' exibirá TODOS os efeitos de Pets, independentemente da classe.
				/pet light, lightpet, lightpets -> Exibe todos os PET's de Luz.
				/pet item, items {harvesting|mining|fishing} -> Exibe todos os itens afetados pelos bônus da classe de PET's informada.
				'''
			FAQ:
				'''
				Q: Haverá conteúdo entre mods? & O Pets Overhaul é compatível com o mod X?
				A: Atualmente, o Addon Calamity está disponível com o nome: 'Pets Overhaul: Calamity Addon'! Pode haver mais no futuro.
				Q: Por que eu estou aleatoriamente conseguindo peixes, caixas e etc no meu inventário?
				A: 99% das vezes, é devido ao seu mod de auto-pesca pescando peixes e ativando sua Fortuna em Pesca. (use /pet fortune para mais informações)
				Q: Existe uma maneira de eu ver os efeitos atualizados dos Pets adicionados pelo Pets Overhaul?
				A: Use /pet pets all e /pet light ou visite: terrariamods.wiki.gg/wiki/Pets_Overhaul para acessar a nossa wiki.
				'''
			FortuneInfo:
				'''
				Todos os status de fortuna aumentam a quantidade de itens obtidos na referida categoria de itens. (Ex. Minérios = Fortuna de Mineração)
				Eles funcionam com 100% de eficácia para itens ganhos por Pets da mesma Classe, e 50% para itens ganhos por meios que não sejam de PET's.
				Por exemplo: Se você tiver 100 de Fortuna de Colheita, coletar 3 Nascer do Dia manualmente e +2 com a Semente de Abóbora Mágica (Pet Abóbora)
				Resultará em 1,5 (item ganho por meios que não são de pets, 50% eficaz) + 2 (item ganho através do bônus do Pet, 100% eficaz) a mais de Nascer do Dia.
				'''
			FortuneCurrent:
				'''
				[c/90C2AA:Global Fortune] - Enquanto funciona com 100% de eficácia em itens de Pet não classificados,
				funciona com 50% de eficácia em todo o resto. Sua Fortuna Global atual: <global>
				[c/96A8B0:Mining Fortune] - Minérios, gemas etc. Sua Fortuna em Mineração atual: <mining>
				[c/0382E9:Fishing Fortune] - Peixes, caixotes etc. Sua Fortuna em Pescar atual: <fishing>
				[c/CDFF00:Harvesting Fortune] - Ervas, plantas, árvores etc. Sua Fortuna em Colheita atual: <harvesting>
				'''
			VanityPet:
				'''
				Passo 1: Equipe o pet que você não quer visível, mas quer os seus efeitos ativos no slot de Pet.
				Passo 2: Desabilite a visibilidade do Pet atualmente equipado no ícone de olho no slot do Pet.
				Passo 3: 'Use' o Pet que você quer que fique visível pelo seu item no inventário e pronto!
				'''
			LightPetList: Lista de todos os PET's de Luz:
			PetList: Lista de PET's da classe <class>:
			All: todos
			NoPets: Nenhum PET disponível para esta classe. (Talvez você esteja sem um addon para esta classe?)
			Items: Todos os itens afetados pelos efeitos de PET's da classe <class> (Apenas quando obtidos naturalmente):
			ClassArgumentInvalidItems: A classe fornecida é inválida, tente uma das seguintes: {harvesting|mining|fishing}.
			ClassArgumentInvalid: A classe fornecida é inválida, tente uma das seguintes: {all, ability (or cooldown)<petClasses>}.
			ArgumentInvalid: O argumento enviado foi invalido, aqui está a lista de comandos do Pet Overhaul: (comandos não diferenciam maiúsculas de minúsculas)
			UseInMultiplayer: Por favor, use esse comando no Multiplayer! Se você quer ver as habilidades do seu Junimo, use /pet junimo, /pet junimoscoreboard ou /pet junimoleaderboard
			SinglePlayerJunimo: "[c/<color>:O nível de <class> do seu Junimo: <level> A experiência da <class> do seu Junimo: <exp>]"
			LeaderboardList: "[c/<color>:Lista de Jogadores com maior Nível de <class> do Junimo:]"
			PlayerRankings: Nível de <class> de <player>: <level>
		}

		Config: {
			Personalization: Personalização
			ServerPersonalization: Configurações do Lado do Servidor
			HeaderDisplay: Configurações de Exibição
			HeaderSound: Configurações de Áudio
			HeaderGameplay: Configurações de Jogabilidade
			MoreDifficultLabel: Desvantagem do Jogador
			MoreDifficultTooltip:
				'''
				Define a porcentagem de redução de dano causado pelo jogador e o aumento de dano recebido.
				Isto foi implementado porque o Pets Overhaul adiciona um aumento de poder ao jogo. Mínimo 0, Máximo 20%.
				Mantenha em 0 se desejar que isso seja desativado. O recomendado é entre 7% e 10%.
				Isso não terá efeito se você não tiver nenhum tipo de PET equipado.
				'''
			SwapCooldownLabel: Tempo de Recarga da Troca de PET
			SwapCooldownTooltip:
				'''
				Permite que o jogador receba o Debuff de PET Desatento ao trocar de Pet.
				Isto impede que quaisquer benefícios relacionados ao combate fiquem ativos durante esse período.
				(Recomendado manter ativado por razões óbvias de balanceamento.)
				'''
			PhantasmalDragonShootLabel: Rajada de Fogo do Dragão Fantasmal vinda do Dragão
			PhantasmalDragonShootTooltip:
				'''
				Habilita o 3º feitiço do Dragão Fantasmal, Rajada de Bolas de Fogo, para ser lançado da
				boca do Dragão (O Pet Dragão que te segue), em vez do Jogador.
				'''
			NoticeLabel: Aviso de Login
			NoticeTooltip:
				'''
				Habilita mensagens enviadas pelo Pet Overhaul ao entrar no mundo.
				Os avisos podem conter breves informações sobre as últimas atualizações.
				'''
			ShieldLocationLabel: Localização do Escudo de Pet
			ShieldLocationTooltip:
				'''
				Muda onde o Escudo de Pet deve ser exibido quando um Escudo for fornecido pelo seu Pet.
				As opções de Barra de Vida funcionam melhor em monitores com resolução 1920x1080.
				'''
			CooldownDisplayLabel: Interface de Recarga da Habilidade do Mascote
			CooldownDisplayTooltip:
				'''
				Habilita o Texto de Interface que mostra a recarga atual e a recarga base
				das habilidades que usam tempo de recarga pelo seu Mascote.
				Visível apenas se o Mascote ativo atual tiver uma habilidade com tempo de recarga.
				'''
			CooldownDisplayLocationLabel: Posição da Interface de Recarga da Habilidade
			CooldownDisplayLocationTooltip:
				'''
				Determina onde a interface do usuário da habilidade do mascote ficará na tela.
				A posição selecionada será o canto superior esquerdo da interface.
				'''
			ResourceDisplayLabel: Interface de Recursos do Mascote
			ResourceDisplayTooltip:
				'''
				Habilita a visibilidade do texto da interface do usuário, que mostra os recursos do seu Pet ativo no momento ou
				algum tipo de acúmulo (stacks). Não visível por padrão se o Pet atual não tiver acúmulos, etc.
				'''
			ResourceDisplayLocationLabel: Posição da Interface de Recursos do Mascote
			ResourceDisplayLocationTooltip:
				'''
				Determina onde a interface de Recursos do seu Pet estará na tela.
				A posição selecionada será o canto superior esquerdo da interface.
				'''
			DustAmountTooltip: Modifica a quantidade de poeira que vai ser criada para a exibição dos seus Pets que possuem um raio em seus efeitos.
			DustAmountLabel: Quantidade de Poeira do Círculo do Pet
			DustInsideBlocksLabel: Poeira do Círculo do Pet Dentro de Blocos
			DustInsideBlocksTooltip:
				'''
				Habilita se as Poeiras criadas por Pets com efeitos do tipo Raio poderão ou não surgir dentro de blocos.
				Isso pode reduzir a quantidade de poeiras possivelmente desnecessárias, então se você tem problemas de performance, isso pode ser útil.
				'''
			MaxQualityColor1Label: 1ª Cor de Qualidade Máxima
			MaxQualityColor1Tooltip: Ajusta a primeira cor que vai alternar com a segunda nas Qualidades Máximas dos PET's de Luz.
			MaxQualityColor2Label: 2ª Cor de Qualidade Máxima
			MaxQualityColor2Tooltip: Ajusta a segunda cor que vai alternar com a primeira nas Qualidades Máximas dos PET's de Luz.
			HurtSoundLabel: Sons de dor do pet
			HurtSoundTooltip: Habilita efeitos sonoros personalizados adicionados pelos pets quando o jogador recebe dano.
			DeathSoundLabel: Sons de morte do pet
			DeathSoundTooltip: Habilita efeitos sonoros personalizados adicionados pelos pets quando o jogador morre.
			PassiveSoundLabel: Frequência de sons passivos do pet
			PassiveSoundTooltip:
				'''
				Ajusta a frequência com que seu Pet pode emitir um efeito sonoro passivo.
				A opção 'Nunca' desabilitará completamente os efeitos sonoros passivos dos Pets.
				É semelhante aos efeitos sonoros de ambiente do Vanilla. Funciona totalmente no lado do cliente.
				'''
			AbilitySoundLabel: Sons de habilidade do pet
			AbilitySoundTooltip:
				'''
				Ativa os efeitos sonoros dos Pets que tocam ao ativar habilidades, recarregar o tempo de recarga
				e outras coisas semelhantes. (não recomendado desativar, pois esses sons podem ajudar com sua percepção.)
				'''
			LowCooldownSoundLabel: Som de habilidade para tempos de recarga curtos
			LowCooldownSoundTooltip:
				'''
				Ativa o som de recarga da habilidade do Pet mesmo que estejam abaixo do Limite da opção.
				Mantenha isso desativado se não quiser ouvir o efeito sonoro de recarga se estiver abaixo do limite.
				'''
			LowCooldownThresholdLabel: Limite para tempo de recarga curto
			LowCooldownThresholdTooltip:
				'''
				Define o limite para desabilitar curtos tempos de recarga das habilidades dos pets
				de reproduzir sons ao serem recarregados, em Quadros. (60 quadros = 1 segundo)
				Alterar isso não tem efeito se "Som de habilidade para tempos de recarga curtos" estiver ativado.
				'''
			ActivePetSlotPosLabel: Posição do Slot de Mascote Ativo
			ActivePetSlotPosTooltip:
				'''
				Determina onde o Slot de Mascote Ativo exibido no menu de Equipamentos Diversos ficará na Tela.
				O Slot de Mascote de Luz estará logo abaixo de onde este, o Slot de Mascote Regular, for posicionado.
				'''
			PetFoodDropLabel: Bônus de Drops de Comida de Mascote
			PetFoodDropTooltip:
				'''
				Permite que o item Comida de Mascote seja dropado de várias fontes gratuitamente:
				Missões do Pescador, Captura de Peixes, Cortar e Balançar Árvores, Ervas e Extrator.
				Isso não interfere em nenhum drop existente, agindo de forma totalmente separada como um drop bônus.
				Desative isso para desabilitar as formas mencionadas de obter a Comida de Mascote, que é usada nas receitas de criação de Pets.
				'''
			MaxLightPetLabel: Comemoração de PET de Luz Perfeito
			MaxLightPetTooltip:
				'''
				Determina quão intensos são os efeitos/comemoração ao obter um PET de Luz perfeito.
				Não é acionado quando um PET de Luz perfeito é obtido pela Combinação de PETs de Luz no Domador de PETs.
				'''
		}

		LightPetCombineUI: {
			Header: Menu de Combinação de PET's de Luz
			Combine: Combinar
			InfoText:
				'''
				Coloque dois PET's de Luz do mesmo tipo para combiná-los em um só.
				O novo PET de Luz herdará as maiores qualidades de seus pais.
				Não é possível combinar se o resultado não trouxer benefícios.
				'''
			Price: Preço:
			State1: Coloque dois PET's de Luz do mesmo tipo.
			State2: Pronto para combinar.
			State3: Não é possível pagar o custo da combinação.
			State4: Ambos os itens não são PET's de Luz.
			State5: O primeiro item não é um PET' de Luz.
			State6: O segundo item não é um PET' de Luz.
		}

		MissingAddonUI: {
			CalamityMessage:
				'''
				Você sabia que o Mod Pets Overhaul tem um [c/9A0000:Addon do Calamity] oficial?

				Foi detectado que você está usando o Pets Overhaul e o Calamity Mod juntos, sem o addon.

				Encontre "[c/FF0000:Pets Overhaul: Calamity Addon]" na Oficina Steam ou no seu Navegador de Mods!
				[c/828282:Adiciona todos os efeitos de Pets e Pets de Luz do Calamity, e adapta outros sistemas existentes ao Calamity Mod.]
				'''
			Close: Fechar esta mensagem
			Never: Nunca mostrar esta mensagem
		}

		LightPetTooltips: {
			// PerfectChat: Found a perfect [i:<item>] <itemName>!
			// PerfectPopup: Perfect Light Pet!
			NotRolled:
				'''
				[c/828282:O Mascote de Luz maximizado é apenas para exibição!]
				[c/828282:Os status são randomizados quando o Pet é obtido!]
				'''
			SomeStatsAreNotRolled: "[c/828282:Pegue o pet no Inventário para randomizar os status que faltam!]"
			StatTooltipLine: <0> (<1> + <2> por [c/<c>:★], [c/<c>:<3> de <4> ★])
			CreeperEgg:
				'''
				- Aumenta o dano de invocação e corpo a corpo em <Damage> 
				- Aumenta o tamanho do chicote e ataque corpo a corpo em <Size>
				- Aumenta o recuo em <KbIncrease>
				- Aumenta a potência de lentidão do Pet em <Slow>
				'''
			CrimsonHeart:
				'''
				- Aumenta a vida máxima em <Health>
				- Aumenta a cura originada por Pets em <Healing>
				- Aumenta a fortuna de pesca em <Fishing>
				'''
			FairyBell:
				'''
				- Aumenta a aceleração de habilidade do Pet em <Haste>
				- Aumenta a fortuna global em <Fortune>
				- Aumenta a cura originada por Pets em <Heal>
				'''
			JackOLantern:
				'''
				- Aumenta o dano originado por Pets em <Damage>
				- Aumenta a sorte em <Luck>
				- Aumenta a fortuna de colheita em <Fortune>
				- Concede uma chance de <Burn> de queimar inimigos ao atingir
				[c/828282:  • A queimadura dura por 2 segundos.]
				'''
			JewelOfLight:
				'''
				- Aumenta a aceleração de habilidade do Pet em <Haste>
				- Concede um Pulo Bônus. 
				  • O multiplicador de duração é aumentado em <JumpDuration>
				  • Aumenta a aceleração de velocidade durante o Pulo Bônus em <Acceleration>
				  • Aumenta a velocidade máxima durante o Pulo Bônus em <MaxSpeed>
				'''
			MagicLantern:
				'''
				- Aumenta a fortuna de mineração em <Fortune>
				- Aumenta a redução de dano em <DamageReduction>
				- Aumenta a resistência a recuos em <KbResist>
				- Aumenta os escudos originados por Pets em <Shield>
				'''
			ShadowOrb:
				'''
				- Aumenta a potência de lentidão do Pet em <Slow>
				- Aumenta os escudos originados por Pets em <Shield>
				- Aumenta a fortuna de colheita em <Fortune>
				'''
			SuspiciousLookingTentacle:
				'''
				- Aumenta a aceleração de habilidade do Pet em <Haste>
				- Aumenta a potência de lentidão do Pet em <Slow>
				- Aumenta o dano originado por Pets em <Damage>
				- Aumenta os escudos originados por Pets em <Shield>
				- Aumenta a cura originada por Pets em <Heal>
				- Aumenta o Dano Crítico à Distância em <Crit>
				- Aumenta a Penetração de Armadura fixa de Invocador em <Pen>
				- Aumenta a Mana Máxima em <Mana>
				- Aumenta o Tamanho Corpo a Corpo em <Size>
				'''
			ToyGolem:
				'''
				- Aumenta a resistência a recuos em <KbResist>
				- Aumenta a vida máxima em <Health>
				- Aumenta a defesa em <Defense>
				- Aumenta os escudos originados por Pets em <Shield>
				'''
			WispInABottle:
				'''
				- Aumenta o dano mágico e à distância em <Damage> 
				- Aumenta a velocidade dos seus projéteis em <Velocity>
				[c/828282:  • Isso inclui projéteis mágicos e à distância.]
				- Aumenta o dano originado por Pets em <PetDamage>
				'''
		}

		PetItemTooltips: {
			AmberMosquito:
				'''
				- Cavar um minério, joia, ou extraível tem <oreChance>% de chance
				  de dar ao jogador um minério ou joia aleatória normalmente dropada
				  de blocos de limo e semelhantes.
				  • Minérios e gemas menos valiosas tem mais tendência de dropar.
				'''
			EatersBone:
				'''
				- Concede <moveSpd>% de velocidade de movimento e <jumpSpd>% de velocidade de pulo.
				- Permite que você pule automaticamente.
				- Aumenta a resistência ao dano de queda em <fallRes> blocos se:
				  • Você estiver em um bioma maligno.
				'''
			BoneRattle:
				'''
				- Aumenta o seu temporizador de acúmulo de regeneração de vida em <extraRegenTime> segundo, por segundo.
				- Dependendo de quanto tempo você está fora de combate, ganhe o seguinte;
				  • Enquanto estiver fora de combate por <stage1Time> segundos, aumenta a regeneração de vida em <stage1Regen>.
				  • Enquanto estiver fora de combate por <stage2Time> segundos, a regeneração é aumentada para <stage2Regen>.
				  • Tenha um escudo de único golpe de <shieldAmount>% de vida enquanto estiver fora de combate por <stage2Time> segundos.
				- Com o Mascote, causar dano não pode definir seu cronômetro de combate abaixo de <stage1Time> segundos.
				'''
			BoneRattleStack: bônus de regeneração
			BabyGrinchMischiefWhistle:
				'''
				- Diminui a velocidade de todos os inimigos que não são chefes em um raio de <slowRange> blocos em <slowAmount>%.
				- Concede um efeito de calor permanente, reduzindo dano proveniente do frio.
				- Todas as armas da Lua de Gelo ganham <dmg>% de dano e <crit>% de chance crítica.
				  Armas Afetadas: <weapons>
				'''
			Nectar:
				'''
				- Concede imunidade a debuffs de Veneno e Envenenado.
				- Diminui a defesa em <def>, dano e chance crítica em <dmgCrit>%.
				- Aumenta o número máximo de lacaios em <maxMinion> e a velocidade de movimento em <moveSpd>%.
				- Todos os ataques têm uma chance de <regularChance>% (<summonChance>% para ataques de invocação) de invocar
				  uma abelha amiga com <beeDmg> de dano base e <beeKb> de recuo.
				  • O Pacote de Colmeia [i:3333] dá uma chance de 33% de invocar uma Abelha Forte em vez de uma normal.
				  • Invocar uma abelha tem um tempo de recarga de <beeCd> segundos.
				'''
			HellCake:
				'''
				- Concede imunidade à lava por <immuneTime> segundos.
				- Enquanto estiver na lava, ganhe o seguinte:
				  • Efeito Flipper [i:187].
				  • <lavaDef> de defesa.
				  • <lavaSpd>% de velocidade de movimento.
				- O buff da Pele de Obsidiana [i:288] agora concede <obbyDef> de defesa e -<obbySpd>% de velocidade de movimento.
				'''
			Fish:
				'''
				- Aumenta a eficácia da Respiração em <breath>%.
				- Enquanto estiver no bioma do Oceano ou Neve, ganhe
				  <moreFp> de poder de pesca e concede o efeito Flipper [i:187].
				  • Enquanto não estiver, ganhe <fp> de poder de pesca.
				- Aumenta capturas específicas de pesca do bioma de Gelo em <catchChance>%.
				  • Itens afetados: <items>
				- Reduz a duração do debuff Gelado (Chilled) em <chilledReduce>%.
				'''
			BambooLeaf:
				'''
				- Pressione a tecla de Atalho da Habilidade do Pet (<keybind>) para entrar em modo de Alerta.
				  • Aumenta sua velocidade de ataque em <alertAs>%, velocidade de movimento em <alertMs>%.
				  • Diminui seu valor de aggro em <alertAggro>.
				  • Ganha Visão de Caçador, assim pode descobrir onde seus inimigos estão.
				  • Valores aumentados por inimigos próximos dentro de <alertRadius> blocos, até <alertMax> inimigos.
				  • Os benefícios duram <alertDuration> segundos e têm um tempo de recarga de <alertCd> segundos.
				- Sempre ganhe <atkSpd>% de velocidade de ataque.
				  • Aumentado em mais <jungleAtkSpd>% enquanto estiver na Selva.
				- Aumenta a quantidade de Bambu [i:4564] que você colhe em <bambooChance>%.
				'''
			BambooLeafStack: inimigos para os quais você está alerta
			BoneKey:
				'''
				- Imunidade completa a toda a Masmorra pré-hardmode.
				  • Incluindo a imunidade a Espinhos especificamente enquanto estiver na Masmorra.
				- Ganhe <armorPen> de penetração de armadura fixa.
				- Ganhe <dungRegen> de regeneração de vida enquanto estiver na Masmorra.
				'''
			ToySled:
				'''
				- Aplica Frostburn de <frostburnTime> segundos ao atingir.
				  • Adiciona efeitos visuais de Frostburn a todas as suas armas e projéteis.  
				- Aplica uma lentidão de <slowAmount>% por <slowTime> segundos ao atingir.
				  • Todos os valores são multiplicados por <frostMult> se a Armadura de Gelo [i:684] completa estiver equipada.
				'''
			StrangeGlowingMushroom:
				'''
				- Acertos recuperam o tempo restante dos buffs em <buffRecover> segundos.  
				  • Possui um tempo de recarga de <cooldown> segundos e só funciona com Buffs.  
				- Sempre aplica o efeito Confuso em você.  
				- Concede permanentemente o buff de Visão Noturna.  
				- Aumenta TODOS os atributos do Jogador em <intIncr> ou <intIncr>%.  
				  • Dano, velocidade de ataque, chance crítica, dano crítico
				  • Pen. de armadura, % de penetração de armadura, recuo
				  • Mana, regen. de mana, tamanho de arma, chance de reserva de munição
				  • Vida, defesa, redução de dano, resistência a recuos
				  • Regen. de vida, aceleração de regen. natural de vida, aggro
				  • Vel. de movimento, vel. de pulo, tempo de asa, resistência a dano de queda
				  • Poder de pesca, sorte, eficácia de respiração, duração de resistência à lava
				  • Velocidade de mineração, vel. de colocação de blocos, vel. de colocação de paredes
				  • Fortuna global, de mineração, de colheita e de pesca
				  • Aceleração de hab. de mascote, dano de mascotes, eficácia de cura e escudos de mascotes
				'''
			FullMoonSqueakyToy:
				'''
				- Multiplica sua chance de crítico por <critMult>x.
				- Reduz seu dano crítico em <crDmgReduction>%.
				- Acertos críticos aplicam o debuff Esfaqueado.
				  • Esfaqueado aumenta o dano recebido de todas as fontes em <stackDmg>% por stack.
				  • Esfaqueado empilha até <maxStacks> vezes.
				- Ao atacar um inimigo com Esfaqueado, ganhe <stackCritDmg>% a mais de dano crítico por stack.
				  • Aplica-se apenas a jogadores com o Pet Bebê Lobisomem.
				'''
			BerniePetItem:
				'''
				- Imunidade a todos os debuffs do tipo queimadura do vanilla.
				- Inimigos dentro do raio de <burnRange> blocos terão seus debuffs do tipo queimadura afetados.
				  • Os debuffs de queimadura deles diminuem 100% mais devagar. (1 segundo do debuff é removido em 2 segundos)
				  • Eles recuperam <burnDrainMana> mana e <burnDrainHealth> saúde a cada segundo.
				  • Só pode drenar Saúde/Mana de até <maxDrain> inimigos.
				'''
			BerniePetItemStack: queimando inimigos em um raio
			UnluckyYarn:
				'''
				- Pressione a tecla de atalho da Habilidade de Pet (<keybind>) para absorver Luz da Lua.
				  • Cure-se ou receba dano entre <moonlightMin> e <moonlightMax> aleatoriamente.
				  • Sorte negativa ou positiva aumenta as chances e a quantia de cura ou dano.
				  • Pode ser usado apenas durante a noite, tem um tempo de recarga de <moonlightCd> segundos.
				- Aumenta a sorte em <flatLuck>.
				- Concede sorte dependendo do ciclo lunar atual.
				  • O mínimo é <minimumMoon> enquanto estiver Lua Cheia e
				   o máximo é <maximumMoon> enquanto estiver Lua Nova.
				  • Funciona apenas durante a Noite. Sorte atual: <moonLuck>
				- Sua sorte total atual: <playerLuck>
				'''
			BlackCatDeath1: <name> andou por baixo de uma escada.
			BlackCatDeath2: <name> agora sabe que: 'A Lua não reproduz luz por si própria, o Brilho da Lua é na verdade a Luz do Sol sendo refletida.'
			BlackCatDeath3: As crenças supersticiosas de <name> acabaram se revelando reais.
			BlackCatDeath4: <name> não teve sorte.
			BlackCatDeath5: O Gato Preto de <name> trouxe má sorte, afinal.
			BlueEgg:
				'''
				- A colheita lhe dá um item aleatório de sua tabela ponderada.
				  • Plantas têm uma chance de <plantChance>%.
				  • Plantas raras têm uma chance de <rarePlantChance>%.
				  • Árvores e qualquer coisa que possa ser cortada têm uma chance de <choppableChance>%.
				  • Todas as tabelas de loot variam muito e têm seus próprios 'drops raros'.
				- Aproximadamente a cada <eggMinute> minutos lhe dá um Ovo. [i:<egg>]
				  • Há uma chance de obter ovos diferentes.
				'''
			GlowTulip:
				'''
				- Dobra TODO o feno coletado. (Incluindo com as Botas de Flor, etc.)  
				- Dá a você <harvestChance>% mais plantas enquanto estiver abaixo da Superfície.
				  • Reduzido para <rarePlantChance>% para plantas raras.
				  • Árvores de pedras preciosas soltam <gemstoneTreeChance>% a mais além disso.
				- Concede uma luz azul, com uma escala de <shineMult>.
				'''
			ChesterPetItem:
				'''
				- Aumenta seu alcance de coleta de itens em <pickupRange> blocos.
				- Aumenta seu alcance de colocação de itens em <placementRange> blocos.
				- Concede <chestDef> defesa enquanto qualquer recipiente estiver aberto.
				'''
			CompanionCube:
				'''
				- Recupera vida equivalente a <manaToHealth>% do seu uso de mana.
				- Recupera mana equivalente a <healthToMana>% do dano que você recebe.
				- Se a doença de mana estiver ativa, reduz a eficácia de suas poções de mana em <manaPotionNerf>%
				  e a recuperação de vida com o uso de mana em -<manaToHealthNerf>%.
				  • Ambos são dobrados se a penalidade de dano mágico da doença de mana
				   estiver reduzindo mais do que o valor inicial, <halfOfSickness>%.
				'''
			CursedSapling:
				'''
				- Aumenta os slots máximos de lacaios em <minionSlot>.
				- Armas da Lua de Abóbora ganham <dmg>% de dano.
				  • Isso aumenta para <ravenDmg>% para o Cajado do Corvo. [i:1802]
				  • Todas as armas afetadas: <weapons>
				- Aumenta o alcance do Chicote em <whipRange>% e a velocidade em <whipSpeed>% por slot de lacaio.
				  • Isso é quadruplicado para a Colheita Sombria. [i:4680]
				  • Só funciona enquanto segura um Chicote.
				'''
			DirtiestBlock:
				'''
				- Minerar qualquer coisa dá <any> moedas de cobre.
				  • Isso inclui tudo, exceto os itens abaixo.  
				- Minerar blocos comuns dá <soil> moedas de cobre.
				  • Itens afetados: <soilItems>  
				- Minerar terra [i:2] dá <dirt> moedas de cobre.
				'''
			BallOfFuseWire:
				'''
				- Ataques criam uma explosão de área de efeito.
				  • O ataque tem <kb>x do seu recuo inicial.
				  • O ataque tem dano base de <dmg>x do dano que você causou.
				  • O ataque tem <armorPen> de penetração de armadura base.
				  • A explosão tem um raio de <size> por <size>.
				  • Há um tempo de recarga de 2 segundos para ser recastado.
				'''
			CelestialWand:
				'''
				- Aumenta sua mana máxima em <maxMana>%.
				- Reduz seus bônus de dano mágico em <dmgPenalty>%.
				- Aumenta o dano mágico em <manaToDmg>% para cada 1 de Bônus de Mana que você tem.
				  • Isso não é reduzido pela redução de bônus de dano mágico.
				- Reduz o dano mágico em 15% ao usar o conjunto Espectro com o Capuz Espectral. [i:1503]
				- Reduz o dano mágico pela quantidade que o Enjoo de Mana está atualmente reduzindo, dividida por 4.
				  • Essa penalidade é aditiva e não substitui o Enjoo de Mana.  
				- Mana Base Atual: <mana> Bônus de Mana Atual: <bonusMana>  
				  Redução Atual de Dano Mágico: <reducedDmg>% Aumento Atual de Dano Mágico: <increasedDmg>%  
				'''
			EyeSpring:
				'''
				- Aumenta a velocidade de pulo em <jumpBoost>%.
				- Aumenta a aceleração de movimento em <acceleration>%.
				- Multiplica a velocidade de subida das asas em <ascNerf>x.
				'''
			ExoticEasternChewToy:
				'''
				- Concede um bônus de salto decente.  
				- Aumenta a velocidade de movimento em <moveSpd>%.  
				- Modifica suas propriedades de Corpo a Corpo da seguinte forma:  
				  • Multiplica o tamanho de armas corpo a corpo por <sizeNerf>x.  
				  • Aumenta o dano de armas corpo a corpo em <dmg>%.  
				  • Aumenta a velocidade de armas corpo a corpo em <meleeSpd>%.  
				'''
			BedazzledNectar:
				'''
				- Se você não tiver uma Asa, concede o seguinte:
				  • Agora você pode voar com Asas de Borboleta por <flight> segundos.
				  • Ganha imunidade a dano de queda.
				  • Perde <healthNerf>% da sua saúde máxima.
				- Se você já tiver uma Asa, concede o seguinte:
				  • Aumenta o tempo de voo em <flight> + <percFlight>% do seu tempo atual.
				'''
			GlommerPetItem:
				'''
				- Concede o buff Aura de Sanidade para todos os Jogadores em um raio de <sanityRange> blocos.
				  • O buff concede <sanityAmount>% de Aceleração de Habilidade de Mascote.
				- Aumenta sua Mana Máxima em <currentHaste>%. (Igual à sua aceleração de habilidade de mascote atual)
				- Recupera <manaRecover> de mana a cada <manaRecoverCd> segundo.
				  • Essa recuperação não é afetada por nenhum fator.
				- Você também pode obter Goop de Glommer ([i:<goop>]) ocasionalmente.
				  • Útil para iluminar coisas e fertilizar! Provavelmente não deveria comer isso.
				'''
			DD2PetDragon:
				'''
				- Multiplica a velocidade das flechas por <arrowVelo>x.
				- Aumenta a penetração das flechas em <arrowPierce>.
				- Multiplica a velocidade das suas balas por <bulletVelo>x.
				- Suas armas de longo alcance especializadas vão criticar
				  inimigos com menos de <threshold>% de saúde o tempo todo.
				  • O limiar diminui para <bossThreshold>% para chefes.
				'''
			JunimoMaxLevelText: Nível Máximo!
			JunimoMaxed: Maximizados
			JunimoUp: Up
			JunimoLevel: A <class> de Junimo está no level <upOrMax>!
			JunimoPetItem:
				'''
				- Permite que você ganhe EXP para cada classe respectiva, melhorando ainda mais os bônus deste Pet.
				  • Coletar qualquer item de Colheita, Mineração e Pesca lhe dá dinheiro dependendo do
				   valor de exp do item, e os níveis são maximizados no nível <maxLvl>. O limite pode ser aumentado matando os seguintes Chefes únicos;
				   Devorador de Mundos ou Cérebro de Cthulhu, Parede de Carne, Qualquer Chefe Mecânico, Plantera, Cultista Lunático<moreBoss>.
				- <harvesting> Nível atual: <harvestLevel> Experiência necessária para o próximo nível: <harvestNext> Experiência total atual: <harvestCurrent>
				  • Ganhe <harvestingProfit> vezes o valor de exp dos itens em moedas de cobre e ganhe <bonusMs>% de velocidade de movimento.
				- <mining> Nível atual: <miningLevel> Experiência necessária para o próximo nível: <miningNext> Experiência total atual: <miningCurrent>
				  • Ganhe <miningProfit> vezes o valor de exp dos itens em moedas de cobre e ganhe <flatHealth> de saúde máxima.
				- <fishing> Nível atual: <fishingLevel> Experiência necessária para o próximo nível: <fishingNext> Experiência total atual: <fishingCurrent>
				  • Ganhe <fishingProfit> vezes o valor de exp dos itens em moedas de cobre e ganhe <bonusDamage>% de aumento de dano.
				'''
			ExpStack: <class> exp até o próximo nível
			BirdieRattle:
				'''
				- Concede imunidade a dano de queda.
				- Te dá uma Asa de Harpia com <flightTime> segundos de tempo de voo.
				  • Pousar não reinicia seu tempo de asa.
				  • Você não pode planar com essas asas.
				  • Você recupera o tempo de asa após o tempo de recarga de <cooldown> segundos ser renovado.
				  • O tempo de recarga começa no momento em que você começa a voar.
				'''
			BirdieRattleStack: tempo de asa restante
			LizardEgg:
				'''
				- Pressione a Tecla de Habilidade do Pet (<keybind>) para escapar de um perigo soltando uma Cauda de Isca.
				  • Ao usar, perca <tailDmgTaken>% da sua saúde máxima. Esse dano não pode ser letal.
				  • Ganhe quadros de invisibilidade, <tailAcc>% de aceleração, <tailSpd>% de velocidade de movimento e -<tailAggro> de aggro por <buffDuration> segundos.
				  • A cauda pode ser recolhida após <tailWait> segundos para recuperar <tailRecover>% de saúde e reembolsar <cdRefund>% do tempo de recarga restante da sua habilidade.
				  • A cauda terá <tailMaxHp>% da sua saúde máxima e pode ser danificada por inimigos.
				  • A habilidade tem um tempo de recarga de <tailCooldown> segundos e pode permanecer ativa por até metade desse tempo.
				- Ganhe <kbResist>% de resistência a recuo.
				- Enquanto estiver com menos de 55% de saúde, você se transforma em um Lihzahrd.
				  • Ganhe <def> de defesa, <moveSpd>% de velocidade de movimento e imunidade a recuo.
				  • Perda de <jumpPenalty>% do seu comprimento de salto e tempo de asa.
				'''
			TartarSauce:
				'''
				- Danificar um inimigo com ataques corpo a corpo concede stacks.
				  • 2 para ataques corpo a corpo verdadeiros, 1 para ataques de projétil corpo a corpo.
				  • Ganhar stacks tem um tempo de recarga de <cooldown> segundos.
				  • Até um máximo de <maxStack> stacks.
				  • Perca um stack a cada <oocTimer> segundo enquanto fora de combate.
				  • Ganhe <meleeSpd>% de velocidade corpo a corpo por stack, máximo <maxMeleeSpd>%.
				  • Perda de <moveSpd>% de velocidade de movimento por stack, máximo -<maxSpd>%.
				  • Ganhe <dmg>% de dano corpo a corpo por stack, máximo <maxDmg>%.
				  • Ganhe <def>% de defesa por stack, máximo <maxDef>%.
				'''
			TartarSauceStack: pilhas de minotauros
			ParrotCracker:
				'''
				- Todos os projéteis lançados por você ou seus Lacaios/Sentinelas têm uma chance de <projChance>% 
				  de serem re-disparados como um novo projétil pelo seu Papagaio.
				  • As propriedades do projétil são as mesmas, exceto com <projDamage>x do dano. 
				- Todos os ataques Corpo a Corpo não-Projéteis, Projéteis de Corpo a Corpo Verdadeiro e acertos de combate aproximado de 
				  Lacaios & Sentinelas têm uma chance de <meleeChance>% de atingir novamente com <meleeDamage>x do dano.
				'''
			PigPetItem:
				'''
				- Comer um alimento tem uma chance de <foodChance>% de não ser consumido.
				  • Reduzido para <potionChance>% para poções.
				- Comer alimentos lhe dá um escudo que escala com o estágio de Bem Alimentado.
				  • Escudo de <shield1>/<shield2>/<shield3> respectivamente para cada estágio de Bem Alimentado.
				  • O escudo persiste por <shieldTime> segundos + 1 segundo para cada duração de Bem Alimentado do alimento consumido.
				  • Isso tem um tempo de recarga de <cooldown> segundos.
				'''
			MudBud:
				'''
				- Danificar inimigos tem uma chance de <chance>% (Aumentado por Aceleração de Habilidade de Mascote) de fazer grandes esporos danificadores aparecerem.
				  • A localização dos esporos é aleatoriamente próxima ao inimigo e eles se movem levemente.
				  • Os esporos causam <dmg>x do dano inicial que os gerou + <flatDmg>.
				  • Os esporos têm um recuo de <kb> e podem atingir até <pen>x antes de desaparecer.
				'''
			DD2PetGato:
				'''
				- Permite que os ataques de sentinelas possam criticar.
				  • Aumenta a chance de crítico da Sentinela em <crit>%.
				  • Isso usa seus bônus de crítico gerais.
				- Aumenta o número máximo de sentinelas em <maxSentry>.
				'''
			DogWhistle:
				'''
				- Aumenta a quantidade de criaturas capturadas em <critter>%.
				  • Reduzido para <rareCritter>% para criaturas raras.
				- Concede <rareCritterCoin> moedas de prata para criaturas raras capturadas.
				- Concede <rareEnemyCoin> moedas de prata para inimigos raros mortos.
				  • Ambos são multiplicados pelo valor de raridade dos inimigos.
				- Mostra a localização de criaturas raras e NPCs aliados com brilho amarelo.
				- Mostra a localização de inimigos raros com brilho roxo.
				'''
			Seedling:
				'''
				- Multiplica o dano que você causa por <dmgPenalty>x.
				- Ganhe <lifesteal>% de roubo de vida. 
				  • Aumentado para <planteraSteal>% para as armas de Plantera.
				   Armas afetadas: <weapons>
				'''
			SpiderEgg:
				'''
				- Danificar inimigos aplica Envenenado por <poisonTime> segundos.
				- Ao danificar um inimigo, remova a imunidade a Envenenado se:
				  • O alvo não tiver imunidade ao debuff Veneno.
				- Ganhe benefícios ao danificar inimigos que já estão Envenenados ou afetados por Veneno
				  • O dano causado aumenta para <poiPerc>x + <poiFlat> para Envenenado, <venomPerc>x + <venomFlat> para Veneno.
				  • O recuo causado é multiplicado por <poiKb>x para Envenenado, <venomKb>x para Veneno.
				  • A chance de crítico aumenta em <poiCrit>% para Envenenado, <venomCrit>% para Veneno.
				'''
			OrnateShadowKey:
				'''
				- Melhora o saque que você ganha de PNJs e de todos os tipos de bolsas de saque.
				  • Não melhora o drop da Bolsa de Saque em si, mas sim seu conteúdo.
				- Saques com chance de drop abaixo de <threshold>% têm sua chance de drop aumentada em <chanceIncrease>%.
				- Se a chance de drop for acima de <threshold>%, a pilha de saque é dobrada com <chanceToDouble>% de chance.
				  • Itens de conjunto não são afetados. (Ex.: Saque é um drop garantido de um de 5 itens)
				  • Itens com pilha máxima de 1 não são afetados.
				'''
			SharkBait:
				'''
				- Ganhe <breath>% a mais de duração da respiração subaquática.
				- Causa <seaCreatureDmg>x de dano a inimigos pescados e
				  receba <seaCreatureResist>x de dano de todos os ataques de inimigos pescados.
				  • Inimigos pescados incluem inimigos que aparecem ao serem capturados com sua vara.
				  • Isso inclui Duke Fishron e semelhantes.
				- Concede <shield> de escudo por <shieldTime> segundos ao capturar qualquer coisa com sucesso.
				'''
			SpiffoPlush:
				'''
				- Concede uma chance de <ammoReserve>% de não consumir munição.
				- Projéteis de longo alcance ganham <armorPen> de penetração de armadura contra inimigos do tipo Zumbi.
				- Matar qualquer inimigo tem <penChance>% de chance de aumentar a penetração do projétil em 1.
				'''
			MagicalPumpkinSeed:
				'''
				- Aumenta todas as plantas e similares que você coleta em <plant>%.
				  • Reduzido para <rarePlant>% para plantas raras.
				- As peças da Armadura de Abóbora agora concedem os seguintes benefícios:
				  • +<health> bônus de saúde máxima
				  • +<harvFort> fortuna de colheita
				'''
			SquashlingHealth: Aumenta a saúde máxima em <hp>
			SquashlingFortune: Fortuna de colheita por <fortune>
			EucaluptusSap:
				'''
				- Permite que você plane enquanto mantém pressionada a tecla de pulo.
				  • Isso é alcançado multiplicando sua velocidade máxima em Y que você pode atingir por <glide>x.
				  • Não concede imunidade a dano de queda, mas planar reinicia seu dano de queda.
				  • Pode ser usado juntamente com Asas, fornecendo ainda mais poder de planagem.
				'''
			TikiTotem:
				'''
				- Permite acertos críticos para todo o dano de invocação. 
				  • Tem -<nonWhipCrit>% de chance para dano de invocação que não seja de chicote.
				  • Tem +<whipCrit>% de chance para dano de invocação com chicote.
				- Concede benefícios extras dependendo da sua velocidade de ataque de chicote.
				  • Aumenta o dano de invocação em <atkSpdToDmg>% da velocidade de ataque do chicote.
				  • Aumenta o alcance do chicote em <atkSpdToRange>% da velocidade de ataque do chicote.
				'''
			Seaweed:
				'''
				- Pressione a tecla de habilidade do Pet (<keybind>) para endurecer o Casco da sua Tartaruga.
				  • Os próximos <hitCount> hits recebidos dentro de <shellDuration> segundos são modificados.
				  • Os hits causam <reducedDmg>% a menos de dano e não causam recuo.
				  • <reflect>% do dano recebido antes da mitigação é refletido de volta para o atacante.
				  • O dano refletido é reduzido para <projReflect>% para danos recebidos por um projétil.
				- Aumenta a defesa em <def>%.
				- Concede <kbResist>% de resistência a recuo.
				- Reduz a velocidade de movimento em <moveSpd>%.
				'''
			SeaweedStack: acertos para suportar
			LightningCarrot:
				'''
				- Aumenta a velocidade de movimento em <flatSpd>%, além de multiplicar a velocidade de movimento por <multSpd>x.
				- Aumenta seu dano igual a <spdToDmg>% do quanto bônus de velocidade de movimento você possui.
				- Inimigos que entram em contato com você são desacelerados em <staticAmount>% por <staticTime> segundos.
				'''
			ZephyrFish:
				'''
				- Aumenta seu poder de pesca dependendo da força do vento atual, 1 por <windFish> mph.
				- Concede uma chance de <regularChance>% de ganhar +1 stack em cada peixe que você capturou, aumentada para <windChance>% se: 
				  • Você estiver no nível da Superfície.
				  • A força do vento for superior a 10 mph.
				  • Seu flutuador estiver do lado oposto de onde o vento está vindo. 
				- Aumenta seu poder de pesca em <anglerPower>% por missão de Pescador completada, máximo de <maxAnglerPower>%.
				  • Missões de Pescador completadas: <anglerQuests>, aumento atual do poder de pesca: <currentAnglerPower>%.
				'''
			EyeOfCthulhuPetItem:
				'''
				- Pressione a tecla de habilidade do Pet (<keybind>) para entrar no 'estado de fúria' antecipadamente.
				  • Ganhe <forcedEnrageMult>% da saúde usada para ficar abaixo de 50% como um escudo extra por <shieldDuration> segundos.
				- No momento em que você estiver abaixo de 50% de saúde e em combate por pelo menos <outOfCombat> segundos,
				  entre em fúria, consumindo toda a sua defesa e redução de dano para pontos de Raiva.
				  • Ganhe <shieldMult>x de pontos de raiva como um Escudo por <shieldDuration> segundos.
				  • O multiplicador de escudo é aumentado para <eocShieldMult>x quando o Escudo de Cthulhu está equipado.
				  • Se o tempo de atraso do seu dash do Escudo de Cthulhu for maior que <frameReduction> quadros, será definido para <frameReduction>.
				  • Aumenta o dano em <defToDmg>% dos pontos de raiva.
				  • Aumenta a velocidade de movimento em <defToSpd>% dos pontos de raiva.
				  • Aumenta a chance de crítico em <defToCrit>% dos pontos de raiva.
				  • [c/f8baba:Você não pode ultrapassar 50% da sua saúde máxima enquanto estiver enfurecido.]
				  • [c/f8baba:Sua defesa e redução de dano são definidos como 0 durante todo o tempo.]
				  • A fúria dura <enrageLength> segundos e tem um cooldown de <enrageCd> segundos.
				'''
			EocEnrage: ENFURECIDO!
			EocCalm: Aliviado.
			EyeOfCthulhuPetItemStack: pontos de raiva
			BrainOfCthulhuPetItem:
				'''
				- Concede a você <lifesteal>% de roubo de vida, mas o quanto você pode roubar de vida
				  depende de um Pool de Saúde, o roubo de vida é reduzido do pool, 
				  e quando o pool está vazio, [c/f8baba:você não pode roubar vida] até que ele tenha saúde novamente.
				  • A quantidade máxima que o pool contém é igual a <maxPool>% da sua saúde máxima.
				  • O pool se recupera +1 de saúde a cada <healthRecovery> segundo.
				'''
			BrainOfCthulhuPetItemStack: acúmulos no pool de saúde
			EaterOfWorldsPetItem:
				'''
				- Ganhe <miningSpeed>% de velocidade de mineração para blocos que não são minérios/gemas.
				- Tenha uma chance de <multipleBreakChance>% de minerar em um raio de <width>x<length> blocos.
				  • Apenas minera minérios/gemas e que sejam do mesmo tipo.
				'''
			KingSlimePetItem:
				'''
				- Pressione a tecla de habilidade do PET (<keybind>) para invocar um Servo de Slime.
				  • O Servo de Slime age da mesma forma que um Slime Azul, mas é mais agressivo,
				   ataca o inimigo mais próximo dentro de 50 blocos; se não houver, segue seu invocador.
				  • Ele também tem 50% mais resistência a recuos do que um Slime Azul comum,
				   <defMult>% extra da Defesa do Jogador, <hpMult>% extra da Saúde do Jogador e
				   causa <dmg> de dano extra, pode criticar e escalar com os bônus gerais do Jogador.
				  • Ao morrer, aplica um debuff de lentidão de <slowAmount>% por <slowDuration> segundos e um debuff pegajoso
				   por <slimyDuration> segundos a todos os inimigos em um raio de <radius> blocos.
				- A habilidade tem um tempo de recarga de <cooldown> segundos e cada Slime dura <lifetime> segundos.
				'''
			KingSlimePetItemStack: Servos de Slime vivos
			QueenBeePetItem:
				'''
				- Cure <extraHeal>% a mais de todas as poções de cura.
				- Ao consumir Mel Engarrafado [i:1134] ou Barbatanas de Mel [i:2314], ajuda os Jogadores em um alcance de <range> blocos.
				  • Recupera <bottledHealth>% da saúde máxima do jogador, ou <honeyfinHealth>% respectivamente.
				  • Concede o buff Mel por <bottledHoneyTime> ou <honeyfinHoneyTime> segundos respectivamente. 
				  • Concede o (de)buff Overdose de Mel por 60 segundos.
				  • Overdose de Mel impede que o Jogador seja curado por outra Abelha de Mel durante a duração.
				  • Overdose de Mel também concede <abilityHaste>% de aceleração de habilidade do PET durante a duração, o que
				   determina com que frequência a habilidade do PET do Jogador pode ser usada.
				  • O Jogador com Abelha de Mel recebe todos os benefícios com metade do efeito e duração total da Overdose de Mel.
				'''
			DeerclopsPetItem:
				'''
				- Receba <dmgReduce>% a menos de dano de inimigos que estejam a pelo menos <reduceRadius> blocos de distância de você.
				- Armazene o dano recebido por <storeDuration> segundos.
				- Pressione a Tecla de Atalho da Habilidade do Mascote (<keybind>) para consumir todo o dano armazenado.
				  • Ganhe um escudo igual a <shieldMult>% do dano armazenado por <shieldDuration> segundos.
				  • Após um breve atraso, ataque todos os inimigos em um cone de <abilityRadius> blocos de comprimento, mirado em direção ao seu mouse,
				   causando dano armazenado + sua defesa. Aumentado pelos seus bônus de Dano Corpo a Corpo e Redução de Dano.
				   Inimigos atingidos no meio do cone terão toda a sua defesa ignorada para o acerto.
				  • O dano do ataque diminui a cada acerto em <dmgReduceStrike>% até <maxDmgReduceStrike>%
				  • Todos os inimigos atingidos são desacelerados em <slow>% por <slowDuration> segundos.
				  • O valor do dano consumido é limitado a <maxStore>% da sua Vida Máxima.
				  • Tem um tempo de recarga de <cooldown> segundos.
				'''
			DeerclopsPetItemStack: dano armazenado
			SkeletronPetItem:
				'''
				- Todo dano que você recebe e inflige será causado ao longo do tempo.
				- Você recebe <recievedMult>x dano e armazena o dano para ser causado ao longo do tempo.
				  • Recebe 1/<recievedHowLong> do dano armazenado a cada segundo.
				  • Isso contará como se você tivesse desviado do ataque inicial, então você não sofre recuo.
				- Inimigos recebem <dealtMult>x dano e armazenam o dano para ser causado ao longo do tempo.
				  • Eles recebem o dano armazenado ao longo de 4 segundos.
				- Se o inimigo pode morrer para o seu hit sem o DOT, ele é instantaneamente executado.
				'''
			SkeletronPetItemStack: danos a serem sofridos ao longo do tempo
			SkeletronDeath1: <name> não pôde conter a maldição do Esqueletron.
			SkeletronDeath2: <name> passou por uma morte dolorosa e lenta.
			SkeletronDeath3: geeettttttt dunked on!!!
			SkeletronDeath4: parece que você teve um tempo ruim ;)
			QueenSlimePetItem:
				'''
				- Ganhe um bônus de Salto muito forte enquanto estiver em uma Montaria, exceto para Montarias de voo infinito.
				- Aumenta o dano das suas Montarias contra inimigos de várias maneiras.
				  • Aumenta o dano da Montaria em <dmg>% e agora conta como dano de PET.
				  • Todos os alvos atingidos são lentificados em <slowAmount>% por <slowDuration> segundos.
				  • Você ganhará <shieldAmount> pontos de escudo por <shieldDuration> segundos com um tempo de recarga de <cooldown> segundos.
				'''
			SkeletronPrimePetItem:
				'''
				- Ganha <dmg>% de dano, <crit>% de chance de crítico e <def>x de defesa enquanto tiver algum escudo ativo.
				- Concede 5 escudos.
				  • Escudos estão disponíveis apenas quando você está com 100% de vida, abaixo de 100%, 75%, 50% e 25% de vida, respectivamente.
				  • Todos os escudos têm um valor igual a <shieldMaxHealthAmount>% da sua vida máxima.
				  • Um escudo se recupera a cada <shieldCooldown> segundos.
				  • Um escudo persiste por <shieldLifetime> segundos após receber dano, depois desaparece.
				'''
			SkeletronPrimePetItemStack: escudos disponíveis
			DestroyerPetItem:
				'''
				- Concede <defMultIncrease>% a mais de defesa.
				- Se você tiver o efeito de Pele de Ferro [i:292], ganhe <ironskinDef> de defesa e <miningFortune> de Fortuna de Mineração.
				- Aumenta a quantidade de minérios, gemas ou simplesmente qualquer coisa relacionada à mineração coletada.
				  • O aumento é igual a <defMultChance>% da sua defesa + <flatAmount>%.
				'''
			TwinsPetItem:
				'''
				- Ganhe benefícios dependendo se você estiver perto ou longe do seu alvo.
				- Se o seu alvo estiver dentro de <closeRange> blocos, reduza a defesa dele permanentemente em <defReduce>
				  e aplique o debuff Chamas Amaldiçoadas nele por <cursedTime> segundos.
				- Se o seu alvo estiver fora de <longRange> blocos, cause <hpDmg>% da vida do alvo como dano bônus.
				  • O dano máximo de vida é reduzido para <bossHpDmg>% e é limitado a <bossCap> de dano para chefes.
				  • Os efeitos de %hp de dano escalam com seus bônus de dano.
				- Acionar qualquer um dos efeitos tem um tempo de recarga de <hpDmgCooldown> segundos.
				'''
			EverscreamPetItem:
				'''
				- Multiplica sua chance de crítico mágico por <magicCritNerf>x.
				- Aumenta sua mana máxima em <maxMana>.
				- Ataques mágicos críticos recuperam <missingMana>% do seu mana faltante + <flatMana>.
				  • Isso pode ser ativado a cada <manaRecoveryCd> segundos.
				- Ganhe dano e chance de crítico dependendo da quantidade de mana que você possui.
				  • Concede <dmg>% de dano mágico e <crit>% de chance de crítico enquanto estiver com 100% de mana.
				'''
			MartianPetItem:
				'''
				- Voar horizontalmente economiza até <wingTimeSave>% do tempo de asa.
				  • Por exemplo, voar em um caminho cruzado economizará metade desse tempo.
				   Voar completamente na vertical acabará economizando 0 tempo de asa.
				- Aumenta toda a aceleração em <acc>%.
				- Multiplica a velocidade de voo horizontal por <speedMult>x, e a aceleração por <accMult>x.
				- Aumenta a velocidade de voo horizontal e a aceleração em <flatSpdAcc>%.
				'''
			DD2OgrePetItem:
				'''
				- Transforma você em um tanque imóvel e robusto literal. 
				  • Todos os efeitos são desativados se qualquer montaria estiver em uso.
				- Nerfando você por:
				  • Multiplicar a velocidade de movimento do jogador por <moveSpdNerf>x, a velocidade de ataque de ataques corpo a corpo verdadeiro por <atkSpdNerf>x,
				   a velocidade horizontal das asas e a aceleração por <horizontalNerf>x, e as velocidades de ascensão vertical por <verticalNerf>x.
				  • Reduzir o dano não corpo a corpo em <dmgNerf>%, desativar a mudança de direção enquanto ataca, e diminuir pela metade o tempo de voo das asas.
				- Mas buffando você por:
				  • Multiplicar o tamanho, dano e recuo de ataques corpo a corpo verdadeiro por <trueMeleeMults>x, a defesa por <defMult>x.
				  • Aumentar a chance de crítico de ataques corpo a corpo verdadeiro em <trueMeleeCrit>%, a saúde máxima em <healthIncrease>%, a redução de dano em <damageReduction>%.
				  • Concede imunidade a recuos.
				'''
			DukeFishronPetItem:
				'''
				- Multiplica seu poder de pesca por <baseMult>x + <anglerFishingPower> por missão do Pescador, máximo de 1x.
				  • Missões do Pescador concluídas: <anglerQuests>, Multiplicador atual de Poder de Pesca: <currentAnglerWithBaseMult>x
				- Ganha <flatChance>% + <fishingPowerChance>% do seu poder de pesca como chance de drop duplo.
				- Ganha <bobberChance>% de chance de lançar um flutuador extra junto com o atual.
				'''
			LunaticCultistPetItem:
				'''
				- Pressione sua Tecla de Troca de Habilidade (<switchKeybind>) para alternar entre os feitiços.
				- Pressione sua Tecla de Habilidade do Pet (<keybind>) para usar seu feitiço atual.
				  • Todas as habilidades têm o mesmo tempo de recarga de <cooldown> segundos.
				<tooltip>
				'''
			LunaticCultistPetItemStack: magia
			DragonIceName: "[c/baf2ef:Névoa de Gelo]"
			DragonIce:
				'''
				  • Cria uma Névoa de Gelo no seu cursor, que viaja em uma direção aleatória,
				   gerando Fragmentos de Gelo ao longo do caminho, atravessando blocos.
				  • Tanto a Névoa quanto os Fragmentos causam <damage> de dano base aos inimigos atingidos.
				  • Inimigos atingidos por eles são desacelerados em <slowAmount>% por <slowTime> segundos.
				'''
			DragonLightningName: "[c/00ffd1:Orbe de Raio]"
			DragonLightning:
				'''
				  • Cria um Orbe de Raio no seu cursor, que gradualmente envia Raios na direção
				   onde o seu cursor está, atingindo continuamente os inimigos que os tocam.
				  • O Orbe causa <orbDmg> de dano base com <orbPen> de penetração de armadura,
				   aplicando também uma desaceleração de <orbSlow>% brevemente.
				  • Os Raios causam <strikeDmg> de dano base com <strikePen> de penetração de armadura,
				   aplicando também uma desaceleração de <strikeSlow>% brevemente.
				'''
			DragonFireName: "[c/ff9a00:Rajada de Bolas de Fogo]"
			DragonFire:
				'''
				  • Começa a disparar Bolas de Fogo em direção ao seu cursor <fireballAmount> vezes dentro de <fireballDuration> segundos.
				  • As Bolas de Fogo explodem ao impactar qualquer coisa, causando <fireDmg> de dano base e <kb> de recuo.
				  • Inimigos atingidos recebem o debuff Daybreak por <burnSeconds> segundos.
				  • Habilitar/Desabilitar a Rajada de Bolas de Fogo do Dragão Fantasmal na opção de configuração do Dragão pode permitir que
				   as Bolas de Fogo sejam lançadas da boca do Dragão, em vez de do Jogador. Atualmente: <enabled>
				'''
			DD2BetsyPetItem:
				'''
				- Atingir inimigos com ataques à distância aplica o debuff Queen's Damnation.
				  • O debuff é aplicado por <debuffTime> segundos.
				  • O debuff acumula até <maxStack> stacks.
				  • Cada stack reduz a defesa do alvo em <defDecrease>%.
				- Se qualquer jogador matar um inimigo com Queen's Damnation,
				  ele recupera <missingHpSteal>% de sua vida faltante por stack.
				  • A recuperação é aumentada em <maxStackIncr>% se o alvo estava com o número máximo de stacks.
				'''
			IceQueenPetItem:
				'''
				- Em vez de sofrer dano fatal, entre em um estado de congelamento por <frozenTombTime> segundos.
				  • Durante o congelamento, desacelere todos os inimigos em um raio de <range> blocos em <slowAmount>%.
				  • Enquanto congelado, seja imune a todos os tipos de dano.
				  • Recupere <healthRecovery> de vida e ganhe <shield> de escudo por <shieldDuration> segundos.
				  • Após o término do congelamento, cause <baseDmg> de dano base a todos os inimigos na área de desaceleração.
				  • Ganhe imunidade a todos os tipos de dano por <postTombImmunity> segundos a mais além da imunidade do congelamento.
				  • Esse efeito tem um cooldown de <tombCooldown> minutos.
				'''
			PlanteraPetItem:
				'''
				- Acertos à distância em inimigos causarão dano bônus dependendo
				  da percentagem de vida faltante deles.
				  • O dano que aumenta pode chegar até <maxAmount>%.
				  • O aumento de dano sobe de forma não linear, 
				   quanto menor a saúde, maior o bônus de dano.
				'''
			MoonLordPetItem:
				'''
				- Pressione a tecla de alternância de Habilidade do PET (<switchKeybind>) para alternar os efeitos deste Pet.
				<tooltip>
				'''
			MoonLordPetItemStack: bônus de classe
			MeleeTooltip:
				'''
				- Bônus Corpo a Corpo:
				  • Aumenta a redução de dano em <dr>%.
				  • Aumenta a velocidade de ataque corpo a corpo em <meleeSpd>%.
				  • Aumenta o dano corpo a corpo em <meleeDmg>%.
				  • Aumenta a defesa em <def>.
				  • Reduz a velocidade de movimento em <ms>%.
				'''
			RangedTooltip:
				'''
				- Bônus à Distância:
				  • Aumenta a penetração de armadura de armas à distância em <armorPen>.
				  • Aumenta a chance de crítico de armas à distância em <rangedCrit>%.
				  • Aumenta o dano crítico de armas à distância em <rangedCritDmg>%.
				  • Aumenta o dano de armas à distância em <rangedDmg>%.
				  • Reduz a vida máxima em <hp>%.
				'''
			MagicTooltip:
				'''
				- Bônus Mágico:
				  • Aumenta a mana máxima em <mana>.
				  • Diminui o custo de mana em <manaCost>%.
				  • Aumenta a chance de crítico de dano mágico em <magicCrit>%.
				  • Aumenta o dano mágico em <magicDmg>%.
				  • Reduz a vida máxima em <hp>%.
				'''
			SummonerTooltip:
				'''
				- Bônus de Invocação:
				  • Aumenta o alcance de chicotes em <sumRange>%.
				  • Aumenta a velocidade de ataque de chicotes em <sumSpd>%.
				  • Aumenta o número máximo de lacaios em <sumMax>.
				  • Aumenta o número máximo de sentinelas em <sumMaxSentry>.
				  • Reduz a vida máxima em <hp>%.
				'''
			ResplendentDessert:
				'''
				- Melhora o dano das suas Montarias contra inimigos de várias maneiras.
				  • Aumenta o dano da Montaria em <dmg>% e agora conta como dano de PET.
				  • Com um tempo de recarga de <cooldown> segundos, os acertos da sua Montaria invocarão um Servo de Slime em
				   cima do alvo atingido e você ganhará <shieldAmount> pontos de escudo por <shieldDuration> segundos.
				  • O Servo de Slime age da mesma forma que um Slime Azul, mas é mais agressivo,
				   ataca o inimigo mais próximo dentro de 50 blocos; se não houver, segue seu invocador.
				  • Ele também tem 50% mais resistência a recuos do que um Slime Azul comum,
				   <defMult>% extra da Defesa do Jogador, <hpMult>% extra da Saúde do Jogador e
				   causa <baseDmg> de dano extra, pode criticar e escalar com os bônus gerais do Jogador.
				  • Cada Servo de Slime tem <lifetime> segundos de vida útil antes de morrer.
				'''
			Carrot:
				'''
				- Cada pulo que for mais da metade concede 1 stack.
				  • Concede <moveSpeed>% de velocidade de movimento por stack.
				  • Concede <jumpSpeed>% de velocidade de pulo por stack.
				  • Pode acumular até 10 vezes.
				  • Redefine para 0 stacks se não ganhar um stack em 4 segundos.
				'''
			CarrotStack: pilhas de saltos de coelho
		}

		SimpleTooltips: {
			AmberMosquito: - Minerar minérios, gemas etc. tem chance de dropar um item valioso aleatório.
			EatersBone:
				'''
				- Aumenta a velocidade de movimento e pulo.
				- Aumenta a resistência a dano de queda ao estar em um bioma maligno.
				- Habilita pulo automático.
				'''
			BoneRattle:
				'''
				- Aumenta a aceleração de regeneração.
				- Quando fora de combate, ganha regeneração de vida.
				  • Quando fora de combate por muito tempo, a regeneração aumenta e ganha um escudo.
				  • Você não perde toda a regeneração ao causar dano.
				'''
			BabyGrinchMischiefWhistle:
				'''
				- Desacelera inimigos em um raio.
				- Concede efeito permanente de calor.
				- Armas baseadas na Lua de Gelo ganham dano e crítico bônus.
				'''
			Nectar:
				'''
				- Concede imunidade a Veneno e Envenenado.
				- Reduz ligeiramente a defesa, dano e crítico.
				- Aumenta o número máximo de lacaios e velocidade de movimento.
				- Acertos em inimigos podem raramente gerar abelhas.
				'''
			HellCake:
				'''
				- Concede imunidade à lava, e enquanto estiver nela ganha;
				  • Defesa, velocidade de movimento e efeito flipper.
				- Enquanto a Pele de Obsidiana estiver ativa, ganha defesa mas reduz velocidade de movimento.
				'''
			Fish:
				'''
				- Aumenta a eficácia da respiração.
				- Ganha poder de pesca.
				  • No bioma Oceano ou Neve, ganha mais e tem o efeito flipper.
				- Reduz a duração do debuff Gelado (Chilled).
				- Aumenta capturas de pesca baseadas no bioma de Gelo.
				'''
			BambooLeaf:
				'''
				- Ganha velocidade de ataque.
				- Pressione a tecla de habilidade do Pet (<keybind>) para entrar em modo alerta.
				  • Por inimigo alertado, ganha velocidade de ataque, movimento e reduz aggro.
				  • Ganha o efeito de Caçador.
				- Ganha mais bambu.
				'''
			BoneKey:
				'''
				- Ganha imunidade às ameaças da Masmorra pré-hardmode.
				- Ganha penetração de armadura.
				- Ganha regeneração de vida enquanto estiver na Masmorra.
				'''
			ToySled:
				'''
				- Ao atingir, aplica Queimadura de Gelo (Frostburn) e Lentidão.
				  • Amplifica os efeitos quando a Armadura de Gelo completa estiver equipada.
				'''
			StrangeGlowingMushroom:
				'''
				- Ao atingir, aumenta as durações restantes dos seus buffs.
				- Sempre fica confuso e tem visão noturna.
				- Aumenta todos os status.
				'''
			FullMoonSqueakyToy:
				'''
				- Aumenta a chance de crítico, mas reduz o dano crítico.
				- Acertos críticos aplicam o debuff Esfaqueado (Mauled).
				  • Inimigos com o debuff recebem mais dano.
				- Você ganha dano crítico bônus contra inimigos esfaqueados.
				'''
			BerniePetItem:
				'''
				- Imunidade a todos os debuffs do tipo queimadura vanilla.
				- Rouba mana e saúde de inimigos queimando próximos,
				  enquanto também faz as queimaduras deles durarem mais.
				'''
			UnluckyYarn:
				'''
				- Pressione a tecla de habilidade do Pet (<keybind>) para se curar ou sofrer dano aleatoriamente.
				- Concede sorte.
				- Aumenta ou reduz a sorte com base no ciclo Lunar atual.
				'''
			BlueEgg:
				'''
				- Coletar itens do tipo planta tem chance de dropar um item bônus.
				- As tabelas diferem entre plantas, plantas raras e semelhantes a árvores.
				'''
			GlowTulip:
				'''
				- Aumenta os drops de feno.
				- Ganha mais drops de colheita quando abaixo da superfície.
				- Ganha mais drops de Árvore de Pedras Preciosas.
				- Lhe dá um brilho azul.
				'''
			ChesterPetItem:
				'''
				- Aumenta seu alcance de pegar e colocar itens.
				- Aumenta a defesa quando um contêiner está aberto no momento.
				'''
			CompanionCube:
				'''
				- Uma porção da mana usada curará você.
				- Uma porção do dano recebido recuperará sua mana.
				- O debuff Enjoo de Mana é mais eficaz.
				'''
			CursedSapling:
				'''
				- Aumenta os slots máximos de lacaios.
				- As armas da Lua de Abóbora ganham dano bônus.
				- O alcance e a velocidade do chicote escalam com a quantidade de slots de lacaios.
				'''
			DirtiestBlock:
				'''
				- Minerar qualquer coisa lhe dá moedas.
				  • Sendo a maior quantidade na terra, a segunda maior nos blocos de solo,
				   enquanto qualquer outra coisa dá a menor quantidade.
				'''
			BallOfFuseWire:
				'''
				- Ao atingir, cria explosões.
				  • Este ataque escala com o acerto que o desencadeia.
				'''
			CelestialWand:
				'''
				- Aumenta a mana máxima.
				- Reduz os bônus de dano mágico.
				- Mana bônus (Mana vinda de equipamentos etc.) que você tem aumentará seu dano mágico.
				'''
			EyeSpring:
				'''
				- Aumenta drasticamente sua velocidade de pulo.
				  • A velocidade de pulo é menor para propósitos de voo.
				- Aumenta a aceleração.
				'''
			ExoticEasternChewToy:
				'''
				- Concede a você um pulo bônus.
				- Aumenta a velocidade de movimento.
				- Reduz levemente o tamanho do corpo a corpo.
				- Aumenta o dano e a velocidade do corpo a corpo.
				'''
			BedazzledNectar:
				'''
				- Se você não tem asas:
				  • Você ganha Asas de Borboleta enfraquecidas, mas perde alguma vida máxima.
				- Se você tem asas:
				  • Você ganha tempo de asa extra.
				'''
			GlommerPetItem:
				'''
				- Dá Aceleração de Habilidade de Mascote para jogadores próximos.
				- Aumenta sua mana máxima dependendo do status de Aceleração de Habilidade de Mascote.
				- Recupera mana gradualmente, de forma diferente da recuperação de mana natural.
				- Tem chance de receber a Gosma de Glommer ocasionalmente.
				'''
			DD2PetDragon:
				'''
				- Reduz a velocidade das flechas, mas aumenta a penetração delas.
				- Aumenta muito a velocidade das balas.
				- Armas especializadas sempre farão ataques críticos em inimigos com pouca vida.
				'''
			JunimoPetItem:
				'''
				- Habilita o sistema de subida de nível para Mineração, Pesca e Colheita.
				- Dependendo do seu nível atual, você ganha aumentos de status e dinheiro pelos itens coletados.
				'''
			BirdieRattle:
				'''
				- Ganha imunidade a dano de queda.
				- Ganha asas que funcionam com o sistema de combustível.
				  • Quando seu 'tempo de asa' acaba, você não pode voar ou planar até a recarga ser reiniciada.
				'''
			LizardEgg:
				'''
				- Pressione a Tecla de Habilidade do Pet (<keybind>) para largar uma Cauda Falsa.
				  • Você vai receber uma pequena quantidade de dano.
				  • Você se moverá extremamente rápido e ganhará quadros de invencibilidade por um tempo.
				  • Depois, você pode pegar a cauda para recuperar alguma vida e reembolsar o tempo de recarga.
				- Ganha resistência a recuos o tempo todo, e se transforma em um Lihzahrd quando estiver abaixo de 55% de vida.
				'''
			TartarSauce:
				'''
				- Ao atingir com ataques corpo a corpo, você ganha acúmulos.
				  • Para cada acúmulo, ganha atributos de corpo a corpo, mas será levemente desacelerado.
				  • Perde acúmulos gradualmente fora de combate.
				'''
			ParrotCracker:
				'''
				- Todos os projéteis seus ou de seu lacaio têm uma chance de disparar um novo projétil.
				- Ataques Corpo a Corpo Não-Projéteis e golpes diretos de seus lacaios podem golpear duas vezes.
				'''
			PigPetItem:
				'''
				- Consumir comidas & poções tem uma chance de não ser consumido.
				- Comer itens alimentares lhe concede um escudo dependendo da fase de Bem Alimentado.
				'''
			MudBud:
				'''
				- Ao atingir, tem chance de invocar um esporo causador de dano.
				  • O esporo escala com o acerto que o aciona.
				'''
			DD2PetGato:
				'''
				- Permite que os ataques de sentinela causem críticos.
				- Aumenta a contagem máxima de sentinelas.
				'''
			DogWhistle:
				'''
				- Aumenta as criaturas capturadas.
				- Ganha dinheiro ao matar ou capturar um inimigo ou criatura rara respectivamente.
				- Permite que você veja todos os NPCs Raros em qualquer lugar na sua tela.
				'''
			Seedling:
				'''
				- Reduz todo o dano que você causa.
				- Concede roubo de vida em todo o dano que você causa.
				'''
			SpiderEgg:
				'''
				- Ao atingir, aplica o debuff Envenenado e remove a imunidade do inimigo ao Envenenado.
				- Tem seus golpes amplificados nos inimigos dependendo do debuff que eles possuem.
				  • Mais amplificação se possuírem o debuff Veneno, menos se possuírem o debuff Envenenado.
				'''
			OrnateShadowKey:
				'''
				- Aumenta a obtenção de itens de NPCs e sacos de itens.
				- Se a chance do item for abaixo de uma certa taxa, a chance de queda dele é aumentada.
				- Se não for, possui a chance de ter seu acúmulo duplicado.
				'''
			SharkBait:
				'''
				- Aumenta o tempo de respiração debaixo da água.
				- Cause mais dano a, e receba menos dano de inimigos pescados.
				- Ganha um escudo ao capturar com sucesso qualquer coisa com sua vara.
				'''
			SpiffoPlush:
				'''
				- Reduz o consumo de munição.
				- Projéteis à distância ganham penetração de armadura bônus contra inimigos do tipo Zumbi.
				- Seus projéteis podem continuar atravessando um inimigo após matá-lo.
				'''
			MagicalPumpkinSeed:
				'''
				- Aumenta os itens de Colheita reunidos (plantas etc.).
				- Peças de armadura de Abóbora concedem vida bônus e fortuna de Colheita.
				'''
			EucaluptusSap:
				'''
				- Enquanto segura a tecla de pulo, permite que você plane.
				  • Não concede imunidade a dano de queda, mas reinicia o dano de queda.
				'''
			TikiTotem:
				'''
				- Permite ataques críticos em todo o dano de invocação. 
				- Ganha bônus de dano de invocação e alcance do chicote baseados na velocidade de ataque do chicote atual.
				'''
			Seaweed:
				'''
				- Pressione a Tecla de Habilidade do Pet (<keybind>) para suportar ataques iminentes.
				  • Você levará menos dano e não receberá recuo.
				  • Você também irá refletir o dano recebido.
				- Aumenta a sua defesa e resistência ao recuo.
				- Reduz a velocidade de movimento.
				'''
			LightningCarrot:
				'''
				- Aumenta a sua velocidade de movimento.
				- Ganha mais dano quanto mais velocidade de movimento você tem.
				- Inimigos que tiverem contato direto com você vão ser fortemente lentificados.
				'''
			ZephyrFish:
				'''
				- Aumenta seu poder de pesca dependendo da força atual do vento.
				- Aumenta a quantidade de peixes capturados, o que sobe ainda mais quando:
				  • Você está acima da superfície, o vento está acima de 10 mph e a isca (bobber) não está encarando o vento.
				- Aumenta a força da pesca baseando-se em quantas missões de pescador você completou.
				'''
			EyeOfCthulhuPetItem:
				'''
				- Ficar com menos de 50% de vida irá lhe colocar no modo Enfurecido. Estando enfurecido:
				  • Você não pode passar dos 50% de vida, e perde toda a sua Defesa & Redução de Dano.
				  • Toda Defesa & Redução de Dano será convertida em um escudo de uso único e
				   ampliamentos de Dano, Crítico e de Velocidade pela duração em que está enfurecido.
				  • Sua investida do Escudo do Cthulhu é melhorada durante esse tempo.
				- Pressione a Tecla de Habilidade do Pet (<keybind>) para se 'Enfurecer' mais cedo.
				'''
			BrainOfCthulhuPetItem:
				'''
				- Ganhe roubo de vida, contudo, o quanto você se cura é limitado por um limite da vida.
				- O limite de vida enche gradualmente ao longo do tempo, caso não tenha nada, você não poderá efetuar o roubo de vida.
				'''
			EaterOfWorldsPetItem:
				'''
				- Escavar blocos que não sejam ou que não contenham minérios e gemas é bem mais veloz.
				- Minerar o próprio minério & o bloco da gema escava os blocos do mesmo tipo próximos.
				'''
			KingSlimePetItem:
				'''
				- Pressione a Tecla de Habilidade do Pet (<keybind>) para invocar um Servo Slime.
				  • O Servo Slime é um Slime Azul melhorado que atacará inimigos próximos.
				  • Escala mais com as suas estatísticas do que o comum.
				  • Após morrer, dá a todos os inimigos próximos debuffs pegajosos e que aplicam lentidão.
				'''
			QueenBeePetItem:
				'''
				- A cura efetuada a você por poções se tornará maior.
				- Ao consumir Mel Engarrafado ou Honeyfin curará e vai aplicar o buff de mel nos outros jogadores próximos.
				- Eles também serão afligidos pelo debuff Overdose de Mel, que aumenta a Aceleração de Habilidade de Mascote,
				  mas isso também significará que eles estarão impossibilitados de se beneficiarem com essa habilidade pela sua duração.
				'''
			DeerclopsPetItem:
				'''
				- Recebe menos dano de inimigos longe de você.
				- Dano recebido é guardado, aperte a Tecla de Habilidade do Mascote (<keybind>) para consumir o dano armazenado.
				  • Dá a ti um escudo baseado no total daquele dano.
				  • Atinge num formato de cone apontado na direção do mouse e causa lentidão nos inimigos.
				  • Os inimigos que estiverem localizados pelo meio do cone tomarão um acerto que ignorará as suas defesas.
				'''
			SkeletronPetItem:
				'''
				- Dano no qual tu acaba recebendo é transferido contra você durando certo tempo.
				- O dano causado é potencializado e é transferido para o alvo com o passar do tempo.
				  • Se esse mesmo for fatal, será garantido abate imediato.
				'''
			QueenSlimePetItem:
				'''
				- Receba um grande fortalecimento do teu Pulo caso em cima de uma montaria.
				- Infligir o dano cavalgando dá melhoria de dano, inflige lentidão no inimigo e dá ao jogador um escudo.
				'''
			SkeletronPrimePetItem:
				'''
				- Tendo escudo funcional e em andamento, você aumenta no crítico, defesa e no ataque.
				- Fica disponível pra ti 5 escudos do qual reativarão num passar gradativo junto à queda de sua vida.
				'''
			DestroyerPetItem:
				'''
				- Aumenta a defesa.
				- Dá melhorias na quantia de def e também duma Fortuna na Mineração caso esteja usufruindo duma Pele de Ferro.
				- Dará fortalecimento nas coisas adquiridas relacionadas à mineração com base de quantidade defesiva.
				'''
			TwinsPetItem:
				'''
				- Após contato contra adversários perto de você, causará abaixamento de defesa e gerará do efeito Chamas Amaldiçoadas.
				- Acertos em inimigos longe da tua visão receberão dano complementar da de quantia ligada ao seu valor em % vida.
				'''
			EverscreamPetItem:
				'''
				- Diminui a sua chance mágica de conseguir acertar críticos.
				- Dará o aumento ao que o seu limite máximo de mana tem disponível.
				- Acertos com o uso das armas de magia sendo em críticos recuperarão em partes ou o restante total na tua quantia de mana.
				- Os bônus que você vir a ganhar no dano nas armas de magias em % dependerão de quanta você possui de momento de mana.
				'''
			MartianPetItem:
				'''
				- Uma quantia em voar pros lados servirá de economia ao que tiver sobrando o de quantia máxima disponível à sua utilidade de planar nas de capacidade voo das asinhas.
				- Aumenta a aceleração.
				- Aumento à vel horizontal somada pela a mesma citada aceleração de voar nelas.
				'''
			DD2OgrePetItem:
				'''
				- Reduz muito a velocidade de movimento e a mobilidade.
				- Reduz muito a velocidade de ataque corpo a corpo verdadeiro.
				- Aumenta muito o dano corpo a corpo verdadeiro, tamanho, crítico e recuo.
				- Aumenta sua vida máxima, defesa, redução de dano e concede imunidade a recuo.
				'''
			DukeFishronPetItem:
				'''
				- Reduz o poder de pesca, o que é compensado por quantas missões de pescador você concluiu.
				- Ganha mais drops de pesca dependendo do poder atual de pesca.
				- Tem chance de lançar várias iscas (bobbers).
				'''
			LunaticCultistPetItem:
				'''
				- Pressione o Atalho de Troca de Habilidade (<switchKeybind>) para mudar de feitiço.
				- Pressione o Atalho de Habilidade do Mascote (<keybind>) para usar o feitiço atual.
				- A Névoa de Gelo atravessa blocos e desacelera muito os inimigos ao acertar.
				- O Orbe de Raio tem alta penetração de armadura, baixo dano e desacelera muito por pouco tempo.
				- A Rajada de Bolas de Fogo tem alto dano e aplica Daybreak ao acertar.
				'''
			DD2BetsyPetItem:
				'''
				- Ataques à distância aplicam o debuff Queen's Damnation ao acertar.
				  • Isso reduz a defesa do alvo em uma % e pode acumular.
				  • Quando um inimigo com o debuff morre, o assassino é curado pela vida que lhe falta.
				'''
			IceQueenPetItem:
				'''
				- Ao invés de tomar dano fatal, entra em um estado congelado.
				  • Você não recebe dano, é curado e ganha um escudo no final.
				  • Enquanto isso, desacelera todos os inimigos próximos e os danifica no final.
				'''
			PlanteraPetItem:
				'''
				- Acertos à distância causam dano bônus dependendo de quão baixa está a vida atual do alvo.
				  • Quanto mais baixa a vida, maior o bônus de dano será.
				'''
			MoonLordPetItem:
				'''
				- Pressione o Atalho de Troca de Habilidade do Mascote (<switchKeybind>) para alternar os efeitos.
				- Corpo a corpo aumenta redução de dano, velocidade corpo a corpo, dano corpo a corpo e defesa.
				- À distância aumenta penetração de armadura à distância, chance de crítico, dano crítico e dano.
				- Magia aumenta mana máxima, crítico mágico, dano e reduz custos de mana.
				- Invocador aumenta alcance do chicote, velocidade, máximo de lacaios e sentinelas.
				- O Corpo a corpo também reduz a velocidade de movimento, enquanto outros reduzem a vida máxima.
				'''
			ResplendentDessert:
				'''
				- Causar dano com montarias aumenta muito o dano,
				  invoca um Servo Slime sobre eles, e concede escudo.
				- Servos Slime são Slimes Azuis modificados e mais fortes que atacam inimigos próximos.
				  • Eles escalam com seus atributos e são mais fracos que os Servos Slime do Príncipe Slime.
				'''
			Carrot:
				'''
				- Ao pular, ganha um acúmulo.
				  • Para cada acúmulo, ganha velocidade de movimento e velocidade de pulo.
				  • Perde acúmulos se você não ganhar nenhum por um tempo.
				'''
		}

		CustomPetEffects: {
			DD2PetGato:
				'''
				- Aumenta o tempo de voo quando você possui asas em <wingTime> segundos.
				carro.
				Dedicado a Furqi por sua contribuição ao Mod.
				'''
			UnluckyYarn:
				'''
				- Pressione a Tecla de Habilidade do Mascote <keybind> para ativar o Véu Lunar por <seconds> segundos.
				  • Isso não pode ser ativado a menos que seja noite.
				  • Enquanto sob o Véu Lunar, você sobreviverá a um golpe fatal e continuará com 1 de vida.
				  • Possui um tempo de recarga de <cooldown> segundos.
				- Se o Véu Lunar proteger você com sucesso, por <postDuration> segundos você irá:
				  • Ganhar <ms>% de Velocidade de Movimento.
				  • Ganhar <manaRegen> de Regeneração de Mana.
				  • Você não poderá regenerar vida.
				O gato de Kinga, a Bruxa.
				'''
			UnluckyYarnStack: duração restante do Véu Lunar
			EucaluptusSap:
				'''
				- Permite que você plane, multiplicando a velocidade máxima no eixo Y por <glide>x.
				  • Isso pode ser feito segurando a barra de espaço e funciona ainda melhor com asas.
				- Pressione a Tecla de Habilidade do Mascote <keybind> para lançar uma 'bolota'.
				  • A bolota é atirada em linha reta na direção em que você estiver virado.
				  • Você também dará um pequeno impulso para trás.
				  • A bolota causa <dmg> de dano e <kb> de recuo, marcando o inimigo atingido.
				  • Pressione a tecla novamente para se teletransportar até o inimigo e atacá-lo novamente.
				  • No segundo ataque, o dano e o recuo são triplicados.
				  • Possui um tempo de recarga de <cooldown> segundos, e a marca permanece no inimigo por <mark> segundos.
				WOOOO YEAHHH LEVE ESSA, SEU DUNGO!!!
				'''
			WispInABottle:
				'''
				- Atacar um inimigo tem uma chance de <Chance> do Fogo-fátuo atacar também.
				  • O ataque bônus causa <Flat> de dano base.
				  • <Mult> do dano causado pelo acerto ativador também é adicionado.
				  • A habilidade não funciona se o mascote Fogo-fátuo não estiver visível.
				"Sempre lembraremos daquela noite."
				'''
		}

		SimpleCustomPetEffects: {
			DD2PetGato:
				'''
				- Aumenta o tempo de voo.
				carro.
				'''
			UnluckyYarn:
				'''
				- Pressione a Tecla de Habilidade do Mascote <keybind> para ativar o Véu Lunar.
				  • Enquanto sob o Véu Lunar, você sobreviverá a um golpe fatal.
				  • Depois disso, ganha velocidade de movimento, regeneração de mana, e a regeneração de vida é desativada.
				  • Só pode ser usado à noite.
				O gato de Kinga, a Bruxa.
				'''
			EucaluptusSap:
				'''
				- Permite planar.
				- Pressione a Tecla de Habilidade do Mascote <keybind> para lançar uma 'bolota'
				na direção em que você estiver virado e dar um pequeno impulso para trás, marcando o inimigo atingido.
				  • Pressione a tecla novamente para se teletransportar até o inimigo e atacá-lo novamente.
				WOOOO YEAHHH LEVE ESSA, SEU DUNGO!!!
				'''
		}

		Buffs: {
			SanityAura: {
				DisplayName: Aura de Sanidade
				Description:
					'''
					Bzzzzt...
					Um Glommer nas proximidades está mantendo seus Mascotes sãos.
					Aumenta a Aceleração de Habilidade de Mascote em 30%.
					'''
			}

			HoneyOverdose: {
				DisplayName: Overdose de Mel
				Description:
					'''
					Uma Abelha de Mel já te alimentou com muito mel! 
					Concede <AbilityHaste>% de Aceleração de Habilidade de Mascote.
					'''
			}

			Mauled: {
				DisplayName: Esfaqueado
				Description: Foi atacado por um Bebê Lobisomem! As fraquezas podem piorar...
			}

			QueensDamnation: {
				DisplayName: Queen's Damnation
				Description: A Rainha Wyvern amaldiçoou esta criatura. A defesa é gradualmente reduzida.
			}

			EocPetEnrage: {
				DisplayName: ENFURECIDO!
				Description:
					'''
					Você está atualmente ENFURECIDO! Tudo o que consegue pensar é em derramamento de sangue!
					Sua defesa e redução de dano estão definidas como 0 e a vida máxima não pode exceder 50%.
					Mas suas capacidades ofensivas são melhoradas e seu Escudo de Cthulhu é mais rápido.
					Pontos de Raiva Atuais: <rage>
					Aumento de Dano Atual: <dmg>%
					Aumento de Velocidade de Movimento Atual: <speed>%
					Aumento de Chance de Crítico Atual: <crit>%
					'''
			}

			HardenedShell: {
				DisplayName: Casco de Tartaruga Endurecido!
				Description:
					'''
					Sua Tartaruga atualmente endureceu o casco dela.
					Acertos recebidos causam menos dano, não dão recuo,
					e serão refletidos para o atacante.
					A quantidade restante de acertos: <hit>
					'''
			}

			ObliviousPet: {
				DisplayName: Mascote Desatento
				Description:
					'''
					Seu mascote não faz ideia do que está acontecendo devido a ter sido trocado recentemente!
					Todos os efeitos relacionados a combate do seu mascote estão desativados!
					'''
			}

			TownPetBunny: {
				DisplayName: Buff de <Name> o Coelhinho
				Description: Aumenta a Fortuna de Colheita em <harv>.
			}

			TownPetCat: {
				DisplayName: Buff de <Name> o Gato
				Description: Aumenta a Fortuna de Pesca em <fish>.
			}

			TownPetDog: {
				DisplayName: Buff de <Name> o Cachorro
				Description: Aumenta a Fortuna de Mineração em <mining>.
			}

			TownPetClumsy: {
